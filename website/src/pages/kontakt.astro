---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { site, whatsappLink } from "../data/site";

const title = "Kontakt";
const description =
  "Schreib Selin Weikard direkt – gern mit Fotos deines Hundes – oder melde dich über WhatsApp. Ganzheitliche Hundegesundheit, online & weltweit.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Kontakt – Selin Weikard",
  url: `${site.domain}/kontakt`,
};
---
<BaseLayout title={title} description={description} path="/kontakt" schema={schema}>
  <section class="bg-gradient-to-b from-petrol-50 to-sand-50">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:py-20 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Kontakt</p>
      <h1 class="mt-3 font-serif text-4xl text-petrol-900 sm:text-5xl">Lass uns über deinen Hund sprechen</h1>
      <p class="prose-lead mx-auto mt-6 max-w-2xl">
        Schreib mir hier direkt – am liebsten mit ein paar Fotos deines Hundes. Ich schaue mir alles
        an und melde mich persönlich. Lieber per WhatsApp? Findest du gleich darunter.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-2xl px-4 pb-20 pt-14 sm:px-6 lg:px-8">
    <!-- ===================== FORMULAR (offen) ===================== -->
    <div id="anfrage-card" class="rounded-3xl border border-sand-200 bg-white p-6 shadow-sm sm:p-9">
      <h2 class="font-serif text-2xl text-petrol-900">Schreib mir – gern mit Fotos</h2>
      <p class="mt-2 text-sm text-sand-600">Fotos von Haut, Fell, Ohren oder einer Auffälligkeit helfen mir, dich besser einzuschätzen.</p>

      <form id="anfrage-form" class="mt-6 space-y-5" novalidate>
        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-sand-700">Dein Name *</span>
            <input type="text" name="name" required autocomplete="name" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-petrol-500 focus:bg-white focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-sand-700">Name deines Hundes</span>
            <input type="text" name="hund" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-petrol-500 focus:bg-white focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-sand-700">E-Mail *</span>
            <input type="email" name="email" required autocomplete="email" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-petrol-500 focus:bg-white focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-sand-700">Telefon (optional)</span>
            <input type="tel" name="phone" autocomplete="tel" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-petrol-500 focus:bg-white focus:outline-none" />
          </label>
        </div>

        <label class="block">
          <span class="text-sm font-medium text-sand-700">Beschreibung *</span>
          <textarea name="message" rows="5" required placeholder="Was beobachtest du bei deinem Hund? Seit wann? Was hast du schon versucht?" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-petrol-500 focus:bg-white focus:outline-none"></textarea>
        </label>

        <div>
          <span class="text-sm font-medium text-sand-700">Fotos (optional, bis zu 8)</span>
          <div class="mt-1.5 rounded-lg border border-dashed border-sand-300 bg-sand-50 p-4">
            <input type="file" name="bilder" multiple accept="image/*" class="w-full text-sm text-sand-600 file:mr-3 file:rounded-full file:border-0 file:bg-petrol-100 file:px-4 file:py-2 file:text-sm file:font-medium file:text-petrol-700 hover:file:bg-petrol-200" />
            <div id="anfrage-preview" class="mt-3 flex flex-wrap gap-2"></div>
          </div>
        </div>

        <label class="flex items-start gap-3 text-sm text-sand-600">
          <input type="checkbox" name="consent" required class="mt-1 h-4 w-4 rounded border-sand-300 text-petrol-600 focus:ring-petrol-500" />
          <span>Ich bin einverstanden, dass meine Angaben und Bilder zur Bearbeitung meiner Anfrage gespeichert und verarbeitet werden. Hinweise in der <a href="/datenschutz" class="underline">Datenschutzerklärung</a>.</span>
        </label>

        <p id="anfrage-msg" class="hidden rounded-lg px-3 py-2 text-sm"></p>

        <button id="anfrage-submit" type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-clay-600 px-6 py-3.5 font-medium text-white transition-colors hover:bg-clay-700 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto">
          Anfrage senden
        </button>
      </form>
    </div>

    <!-- ===================== WHATSAPP (darunter) ===================== -->
    <div class="mt-8 rounded-2xl border border-sand-200 bg-white p-6 shadow-sm sm:p-7">
      <div class="sm:flex sm:items-center sm:gap-5">
        <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-clay-100 text-clay-600">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 004.74 1.21c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm5.52 11.86c-.25.7-1.45 1.34-2 1.42-.53.08-1.2.11-1.94-.12-.45-.14-1.02-.33-1.76-.65-3.1-1.34-5.12-4.46-5.28-4.67-.15-.21-1.26-1.67-1.26-3.19 0-1.52.8-2.27 1.08-2.58.28-.31.61-.38.81-.38h.58c.19 0 .43-.03.66.5.25.6.85 2.07.92 2.22.08.15.13.32.02.53-.1.21-.16.34-.31.52-.15.18-.32.4-.46.54-.15.15-.31.31-.13.6.18.31.8 1.32 1.72 2.14 1.18 1.05 2.17 1.38 2.48 1.53.31.15.49.13.66-.08.17-.21.76-.89.96-1.19.2-.31.4-.25.66-.15.27.1 1.72.81 2.01.96.31.15.51.23.58.35.08.13.08.7-.17 1.4z"/></svg>
        </span>
        <div class="mt-4 flex-1 sm:mt-0">
          <h2 class="font-serif text-xl text-petrol-900">Oder direkt über WhatsApp</h2>
          <p class="mt-1 text-sm text-sand-600">Ein Klick öffnet den Chat mit einer vorbereiteten Nachricht – persönliche Antwort von Selin.</p>
        </div>
        <div class="mt-4 shrink-0 sm:mt-0">
          <Button href={whatsappLink()} variant="primary" external class="wag-hover group">
            <Icon name="paw" class="wag h-5 w-5" />
            Chat starten
          </Button>
        </div>
      </div>
    </div>

    <!-- E-Mail als Alternative -->
    <p class="mt-6 text-center text-sm text-sand-500">
      Kein WhatsApp? Schreib mir alternativ an
      <a href={`mailto:${site.email}`} class="font-medium text-petrol-700 underline underline-offset-2 hover:text-clay-600">{site.email}</a>.
    </p>
  </section>
</BaseLayout>

<script>
  import { supabase } from "../lib/supabase";
  import { uploadMedia } from "../lib/db";

  const form = document.getElementById("anfrage-form") as HTMLFormElement;
  const card = document.getElementById("anfrage-card")!;
  const msg = document.getElementById("anfrage-msg")!;
  const submit = document.getElementById("anfrage-submit") as HTMLButtonElement;
  const fileInput = form.querySelector('input[name="bilder"]') as HTMLInputElement;
  const preview = document.getElementById("anfrage-preview")!;

  function showMsg(text: string, ok = false) {
    msg.textContent = text;
    msg.className = `rounded-lg px-3 py-2 text-sm ${ok ? "bg-petrol-50 text-petrol-800" : "border border-rust-500/30 bg-rust-500/10 text-rust-600"}`;
    msg.classList.remove("hidden");
  }

  fileInput?.addEventListener("change", () => {
    preview.innerHTML = "";
    Array.from(fileInput.files || []).slice(0, 8).forEach((f) => {
      const img = document.createElement("img");
      img.src = URL.createObjectURL(f);
      img.className = "h-16 w-16 rounded-lg object-cover";
      preview.appendChild(img);
    });
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    msg.classList.add("hidden");
    const fd = new FormData(form);
    const name = String(fd.get("name") || "").trim();
    const email = String(fd.get("email") || "").trim();
    const description = String(fd.get("message") || "").trim();
    const hund = String(fd.get("hund") || "").trim();
    if (!name || !email || !description || !fd.get("consent")) {
      showMsg("Bitte fülle Name, E-Mail, Beschreibung aus und stimme der Verarbeitung zu.");
      return;
    }

    submit.disabled = true;
    submit.textContent = "Wird gesendet …";

    const files = Array.from(fileInput?.files || []).slice(0, 8);
    const urls: string[] = [];
    let uploadFailed = false;
    for (const f of files) {
      try { urls.push(await uploadMedia(f, "anfragen")); }
      catch (err) { uploadFailed = true; console.error("Upload fehlgeschlagen:", err); }
    }

    const fullMessage = hund ? `Hund: ${hund}\n\n${description}` : description;
    const base: Record<string, unknown> = {
      name, email,
      phone: String(fd.get("phone") || "").trim() || null,
      channel: "formular", status: "offen", message: fullMessage,
    };
    async function insert(withImages: boolean) {
      const payload = withImages
        ? { ...base, bild_urls: urls }
        : { ...base, message: urls.length ? `${fullMessage}\n\nBilder:\n${urls.join("\n")}` : fullMessage };
      return supabase.from("anfragen").insert(payload);
    }

    let { error } = await insert(true);
    if (error && /bild_urls/i.test(error.message || "")) ({ error } = await insert(false));

    if (error) {
      showMsg("Das hat gerade nicht geklappt. Bitte versuch es später erneut oder melde dich über WhatsApp.");
      submit.disabled = false;
      submit.textContent = "Anfrage senden";
      console.error(error);
      return;
    }

    card.innerHTML = `
      <div class="py-8 text-center">
        <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-petrol-100 text-2xl text-petrol-700">✓</span>
        <p class="mt-5 font-serif text-2xl text-petrol-900">Danke, ${name.replace(/[<>&"]/g, "")}!</p>
        <p class="mx-auto mt-3 max-w-md text-sand-600">Deine Anfrage${urls.length ? " samt Fotos" : ""} ist angekommen. Selin schaut sich alles an und meldet sich persönlich bei dir.</p>
        ${uploadFailed ? '<p class="mx-auto mt-3 max-w-md text-xs text-rust-600">Hinweis: Einige Bilder konnten nicht hochgeladen werden – bei Bedarf sende sie uns bitte über WhatsApp nach.</p>' : ""}
      </div>`;
  });
</script>
