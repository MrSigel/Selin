---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Disclaimer from "../components/Disclaimer.astro";
import { site, whatsappLink } from "../data/site";

const title = "Kontakt & Terminbuchung";
const description =
  "Nimm Kontakt auf: per WhatsApp, über die Online-Terminbuchung oder per Nachricht. Ganzheitliche Hundegesundheits-Begleitung mit Selin Weikard – online, weltweit.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Kontakt – Selin Weikard",
  url: `${site.domain}/kontakt`,
};
---
<BaseLayout title={title} description={description} path="/kontakt" schema={schema}>
  <section class="bg-gradient-to-b from-petrol-50 to-sand-50">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:py-20 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Kontakt</p>
      <h1 class="mt-3 font-serif text-4xl text-petrol-900 sm:text-5xl">Lass uns über deinen Hund sprechen</h1>
      <p class="prose-lead mx-auto mt-6 max-w-2xl">
        Am schnellsten erreichst du mich über WhatsApp. Lieber direkt einen Termin? Nutze die
        Online-Buchung. Oder schreib mir eine Nachricht – ich melde mich persönlich.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-5">
      <!-- Kontaktwege -->
      <div class="space-y-4 lg:col-span-2">
        <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="group flex items-start gap-4 rounded-2xl border border-sand-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:shadow-md">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-clay-100 text-clay-600">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 004.74 1.21c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm5.52 11.86c-.25.7-1.45 1.34-2 1.42-.53.08-1.2.11-1.94-.12-.45-.14-1.02-.33-1.76-.65-3.1-1.34-5.12-4.46-5.28-4.67-.15-.21-1.26-1.67-1.26-3.19 0-1.52.8-2.27 1.08-2.58.28-.31.61-.38.81-.38h.58c.19 0 .43-.03.66.5.25.6.85 2.07.92 2.22.08.15.13.32.02.53-.1.21-.16.34-.31.52-.15.18-.32.4-.46.54-.15.15-.31.31-.13.6.18.31.8 1.32 1.72 2.14 1.18 1.05 2.17 1.38 2.48 1.53.31.15.49.13.66-.08.17-.21.76-.89.96-1.19.2-.31.4-.25.66-.15.27.1 1.72.81 2.01.96.31.15.51.23.58.35.08.13.08.7-.17 1.4z"/></svg>
          </span>
          <span>
            <span class="font-serif text-lg text-petrol-900">WhatsApp</span>
            <span class="mt-1 block text-sm text-sand-600">Schnellste Antwort. Ein Klick öffnet den Chat mit vorbereiteter Nachricht.</span>
            <span class="mt-2 inline-block text-sm font-medium text-clay-600 group-hover:underline">Chat starten →</span>
          </span>
        </a>

        <a href={site.bookingUrl} target="_blank" rel="noopener noreferrer" class="group flex items-start gap-4 rounded-2xl border border-sand-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:shadow-md">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-petrol-100 text-petrol-600">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <span>
            <span class="font-serif text-lg text-petrol-900">Termin buchen</span>
            <span class="mt-1 block text-sm text-sand-600">Direkt einen freien Termin für den Erst-Check auswählen.</span>
            <span class="mt-2 inline-block text-sm font-medium text-petrol-600 group-hover:underline">Zur Buchung →</span>
          </span>
        </a>

        <a href={`mailto:${site.email}`} class="group flex items-start gap-4 rounded-2xl border border-sand-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:shadow-md">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-petrol-100 text-petrol-600">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
          </span>
          <span>
            <span class="font-serif text-lg text-petrol-900">E-Mail</span>
            <span class="mt-1 block text-sm text-sand-600">{site.email}</span>
          </span>
        </a>
      </div>

      <!-- Formular -->
      <div class="lg:col-span-3">
        <div class="rounded-2xl border border-sand-200 bg-white p-7 sm:p-8">
          <h2 class="font-serif text-2xl text-petrol-900">Schreib mir eine Nachricht</h2>
          <p class="mt-2 text-sm text-sand-600">
            Erzähl mir kurz von deinem Hund – ich melde mich persönlich zurück.
          </p>

          <!-- TODO: action auf echten Endpunkt setzen (z. B. Formspree / eigene Serverless-Function) -->
          <form action="#" method="post" class="mt-6 space-y-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="text-sm font-medium text-sand-700">Dein Name</span>
                <input type="text" name="name" required autocomplete="name" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 text-sand-800 focus:border-petrol-500 focus:bg-white focus:outline-none" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-sand-700">E-Mail</span>
                <input type="email" name="email" required autocomplete="email" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 text-sand-800 focus:border-petrol-500 focus:bg-white focus:outline-none" />
              </label>
            </div>
            <label class="block">
              <span class="text-sm font-medium text-sand-700">Wie heißt dein Hund? (optional)</span>
              <input type="text" name="hund" class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 text-sand-800 focus:border-petrol-500 focus:bg-white focus:outline-none" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-sand-700">Deine Nachricht</span>
              <textarea name="nachricht" rows="5" required class="mt-1.5 w-full rounded-lg border border-sand-300 bg-sand-50 px-4 py-2.5 text-sand-800 focus:border-petrol-500 focus:bg-white focus:outline-none"></textarea>
            </label>
            <label class="flex items-start gap-3 text-sm text-sand-600">
              <input type="checkbox" name="datenschutz" required class="mt-1 h-4 w-4 rounded border-sand-300 text-petrol-600 focus:ring-petrol-500" />
              <span>
                Ich bin damit einverstanden, dass meine Angaben zur Bearbeitung meiner Anfrage
                verwendet werden. Hinweise dazu in der Datenschutzerklärung. Die Einwilligung kann
                ich jederzeit widerrufen.
              </span>
            </label>
            <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-clay-600 px-6 py-3.5 font-medium text-white transition-colors hover:bg-clay-700 sm:w-auto">
              Nachricht senden
            </button>
            <p class="text-xs text-sand-500">
              Hinweis: Der Formularversand wird vor dem Launch mit einem Double-Opt-in-fähigen Dienst
              verbunden. Am schnellsten erreichst du mich aktuell über WhatsApp.
            </p>
          </form>
        </div>

        <div class="mt-6">
          <Disclaimer />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
