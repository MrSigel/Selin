---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { site, whatsappLink } from "../data/site";

const title = "Kontakt";
const description =
  "Schreib Selin Weikard direkt über das Kontaktformular – oder melde dich über WhatsApp. Ganzheitliche Hundegesundheit, online & weltweit.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Kontakt – Selin Weikard",
  url: `${site.domain}/kontakt`,
};
---
<BaseLayout title={title} description={description} path="/kontakt" schema={schema}>
  <section class="bg-gradient-to-b from-petrol-50 to-sand-50">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:py-20 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Kontakt</p>
      <h1 class="mt-3 font-serif text-4xl text-petrol-900 sm:text-5xl">Lass uns über deinen Hund sprechen</h1>
      <p class="prose-lead mx-auto mt-6 max-w-2xl">
        Schreib mir hier direkt über das Formular – ich schaue mir alles an und melde mich
        persönlich bei dir. Lieber per WhatsApp? Findest du gleich darunter.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-2xl px-4 pb-20 pt-14 sm:px-6 lg:px-8">
    <!-- ===================== KONTAKTFORMULAR (Bitrix24, eingebettet & offen) ===================== -->
    <div class="rounded-3xl border border-sand-200 bg-white p-4 shadow-sm sm:p-6">
      <iframe
        id="b24-iframe"
        src="https://limit-breakers.bitrix24.site/crm_form_f60i0/"
        title="Kontaktformular"
        loading="lazy"
        class="h-[1100px] w-full rounded-xl border-0 md:h-[860px]"
      ></iframe>
      <p class="px-2 pb-1 text-center text-xs text-sand-400">
        Formular lädt nicht?
        <a href="https://limit-breakers.bitrix24.site/crm_form_f60i0/" target="_blank" rel="noopener noreferrer" class="underline hover:text-petrol-700">In neuem Tab öffnen</a>.
      </p>
    </div>

    <script is:inline>
      // Bitrix24 sendet ggf. die Formularhöhe – iframe entsprechend anpassen
      window.addEventListener("message", function (e) {
        if (!/bitrix24/.test(e.origin || "")) return;
        var d = e.data || {};
        var h = d.height || (d.data && d.data.height) || (typeof d === "number" ? d : null);
        var f = document.getElementById("b24-iframe");
        if (f && h && !isNaN(parseInt(h))) f.style.height = parseInt(h) + 40 + "px";
      });
    </script>

    <!-- ===================== WHATSAPP (darunter) ===================== -->
    <div class="mt-8 rounded-2xl border border-sand-200 bg-white p-6 shadow-sm sm:p-7">
      <div class="sm:flex sm:items-center sm:gap-5">
        <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-clay-100 text-clay-600">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 004.74 1.21c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm5.52 11.86c-.25.7-1.45 1.34-2 1.42-.53.08-1.2.11-1.94-.12-.45-.14-1.02-.33-1.76-.65-3.1-1.34-5.12-4.46-5.28-4.67-.15-.21-1.26-1.67-1.26-3.19 0-1.52.8-2.27 1.08-2.58.28-.31.61-.38.81-.38h.58c.19 0 .43-.03.66.5.25.6.85 2.07.92 2.22.08.15.13.32.02.53-.1.21-.16.34-.31.52-.15.18-.32.4-.46.54-.15.15-.31.31-.13.6.18.31.8 1.32 1.72 2.14 1.18 1.05 2.17 1.38 2.48 1.53.31.15.49.13.66-.08.17-.21.76-.89.96-1.19.2-.31.4-.25.66-.15.27.1 1.72.81 2.01.96.31.15.51.23.58.35.08.13.08.7-.17 1.4z"/></svg>
        </span>
        <div class="mt-4 flex-1 sm:mt-0">
          <h2 class="font-serif text-xl text-petrol-900">Oder direkt über WhatsApp</h2>
          <p class="mt-1 text-sm text-sand-600">Ein Klick öffnet den Chat mit einer vorbereiteten Nachricht – persönliche Antwort von Selin.</p>
        </div>
        <div class="mt-4 shrink-0 sm:mt-0">
          <Button href={whatsappLink()} variant="primary" external class="wag-hover group">
            <Icon name="paw" class="wag h-5 w-5" />
            Chat starten
          </Button>
        </div>
      </div>
    </div>

    <!-- E-Mail als Alternative -->
    <p class="mt-6 text-center text-sm text-sand-500">
      Kein WhatsApp? Schreib mir alternativ an
      <a href={`mailto:${site.email}`} class="font-medium text-petrol-700 underline underline-offset-2 hover:text-clay-600">{site.email}</a>.
    </p>
  </section>
</BaseLayout>
