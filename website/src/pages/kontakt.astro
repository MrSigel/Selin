---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { site, whatsappLink } from "../data/site";

const title = "Kontakt";
const description =
  "Nimm Kontakt auf – am schnellsten und einfachsten über WhatsApp. Ganzheitliche Hundegesundheits-Begleitung mit Selin Weikard – online, weltweit.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Kontakt – Selin Weikard",
  url: `${site.domain}/kontakt`,
};
---
<BaseLayout title={title} description={description} path="/kontakt" schema={schema}>
  <section class="bg-gradient-to-b from-petrol-50 to-sand-50">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:py-20 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Kontakt</p>
      <h1 class="mt-3 font-serif text-4xl text-petrol-900 sm:text-5xl">Lass uns über deinen Hund sprechen</h1>
      <p class="prose-lead mx-auto mt-6 max-w-2xl">
        Alle Anfragen laufen über WhatsApp – ein Klick öffnet den Chat mit einer vorbereiteten
        Nachricht. So bekommst du am schnellsten eine persönliche Antwort von mir.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- WhatsApp: der einzige Anfrageweg -->
    <div class="reveal relative overflow-hidden rounded-3xl border border-sand-200 bg-white p-8 text-center shadow-sm sm:p-10">
      <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-clay-100 text-clay-600">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 004.74 1.21c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm5.52 11.86c-.25.7-1.45 1.34-2 1.42-.53.08-1.2.11-1.94-.12-.45-.14-1.02-.33-1.76-.65-3.1-1.34-5.12-4.46-5.28-4.67-.15-.21-1.26-1.67-1.26-3.19 0-1.52.8-2.27 1.08-2.58.28-.31.61-.38.81-.38h.58c.19 0 .43-.03.66.5.25.6.85 2.07.92 2.22.08.15.13.32.02.53-.1.21-.16.34-.31.52-.15.18-.32.4-.46.54-.15.15-.31.31-.13.6.18.31.8 1.32 1.72 2.14 1.18 1.05 2.17 1.38 2.48 1.53.31.15.49.13.66-.08.17-.21.76-.89.96-1.19.2-.31.4-.25.66-.15.27.1 1.72.81 2.01.96.31.15.51.23.58.35.08.13.08.7-.17 1.4z"/></svg>
      </span>
      <h2 class="mt-6 font-serif text-2xl text-petrol-900 sm:text-3xl">Schreib mir auf WhatsApp</h2>
      <p class="mx-auto mt-3 max-w-md text-sand-600">
        Erzähl mir in ein, zwei Sätzen von deinem Hund. Der Chat öffnet sich mit einer vorbereiteten
        Nachricht – du kannst sie einfach anpassen und absenden.
      </p>
      <div class="mt-8">
        <Button href={whatsappLink()} variant="primary" size="lg" external class="wag-hover group">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 004.74 1.21c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm5.52 11.86c-.25.7-1.45 1.34-2 1.42-.53.08-1.2.11-1.94-.12-.45-.14-1.02-.33-1.76-.65-3.1-1.34-5.12-4.46-5.28-4.67-.15-.21-1.26-1.67-1.26-3.19 0-1.52.8-2.27 1.08-2.58.28-.31.61-.38.81-.38h.58c.19 0 .43-.03.66.5.25.6.85 2.07.92 2.22.08.15.13.32.02.53-.1.21-.16.34-.31.52-.15.18-.32.4-.46.54-.15.15-.31.31-.13.6.18.31.8 1.32 1.72 2.14 1.18 1.05 2.17 1.38 2.48 1.53.31.15.49.13.66-.08.17-.21.76-.89.96-1.19.2-.31.4-.25.66-.15.27.1 1.72.81 2.01.96.31.15.51.23.58.35.08.13.08.7-.17 1.4z"/></svg>
          Chat starten
        </Button>
      </div>
      <ul class="mx-auto mt-8 flex max-w-md flex-col gap-2.5 border-t border-sand-100 pt-6 text-left text-sm text-sand-600">
        <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 shrink-0 text-petrol-500" strokeWidth={3} /> Persönliche Antwort von Selin – kein Bot</li>
        <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 shrink-0 text-petrol-500" strokeWidth={3} /> Unverbindlich – erst schauen wir, ob es passt</li>
        <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 shrink-0 text-petrol-500" strokeWidth={3} /> Termine stimmen wir direkt im Chat ab</li>
      </ul>
    </div>

    <!-- Foto-Anfrage als Alternative -->
    <a href="/anfrage" class="group mt-6 flex items-start gap-4 rounded-2xl border border-sand-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:shadow-md">
      <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-petrol-100 text-petrol-600">
        <Icon name="image" class="h-6 w-6" strokeWidth={1.8} />
      </span>
      <span>
        <span class="font-serif text-lg text-petrol-900">Anfrage mit Fotos</span>
        <span class="mt-1 block text-sm text-sand-600">Lieber Fotos senden – z. B. von Haut, Fell oder einer Auffälligkeit? Nutze das Formular mit Bild-Upload.</span>
        <span class="mt-2 inline-block text-sm font-medium text-petrol-600 group-hover:underline">Zum Foto-Formular →</span>
      </span>
    </a>

    <!-- E-Mail als Alternative -->
    <p class="mt-6 text-center text-sm text-sand-500">
      Kein WhatsApp? Schreib mir alternativ an
      <a href={`mailto:${site.email}`} class="font-medium text-petrol-700 underline underline-offset-2 hover:text-clay-600">{site.email}</a>.
    </p>
  </section>
</BaseLayout>
