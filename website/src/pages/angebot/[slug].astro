---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import Button from "../../components/Button.astro";
import Icon from "../../components/Icon.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { packages, whatsappLink, site } from "../../data/site";
import boxImg from "../../assets/morpheus-meer.jpeg";

export function getStaticPaths() {
  return packages.map((pkg) => ({ params: { slug: pkg.slug }, props: { pkg } }));
}

const { pkg } = Astro.props;
const others = packages.filter((p) => p.slug !== pkg.slug);
const prefill = `Hallo Selin, ich interessiere mich für das Paket „${pkg.name}“ für meinen Hund.`;

const flow = [
  { icon: "chat", t: "Anfrage über WhatsApp", d: "Du meldest dich, wir klären kurz dein Anliegen – unverbindlich." },
  { icon: "calendar", t: "Termin & Zahlung", d: "Wir stimmen deinen Termin direkt im Chat ab, die Zahlung läuft sicher per Link." },
  { icon: "play", t: "Sitzung online", d: "Wir sprechen per Videocall – danach bekommst du alles schriftlich." },
];

const title = `${pkg.name} – ganzheitliche Hundegesundheit`;
const description = `${pkg.tagline} ${pkg.content}`;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: pkg.name,
    description: pkg.content,
    serviceType: "Ganzheitliche Hundegesundheits-Beratung",
    provider: { "@id": `${site.domain}/#organization` },
    areaServed: "Weltweit",
    offers: {
      "@type": "Offer",
      url: `${site.domain}/angebot/${pkg.slug}`,
      availability: "https://schema.org/InStock",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: site.domain },
      { "@type": "ListItem", position: 2, name: "Angebot", item: `${site.domain}/angebot` },
      { "@type": "ListItem", position: 3, name: pkg.name, item: `${site.domain}/angebot/${pkg.slug}` },
    ],
  },
];
---
<BaseLayout title={title} description={description} path={`/angebot/${pkg.slug}`} schema={schema}>
  <!-- ===================== HERO-BAND ===================== -->
  <section class="relative overflow-hidden bg-gradient-to-b from-petrol-50 to-sand-50">
    <div class="mx-auto max-w-7xl px-4 pt-8 pb-14 sm:px-6 lg:px-8">
      <nav aria-label="Brotkrümel" class="text-sm text-sand-500">
        <a href="/angebot" class="transition-colors hover:text-petrol-700">Angebot</a>
        <span class="mx-2">/</span>
        <span class="text-sand-700">{pkg.name}</span>
      </nav>
      <div class="mt-6 max-w-2xl">
        <div class="flex flex-wrap items-center gap-3">
          {pkg.featured && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-clay-100 px-3 py-1 text-xs font-semibold text-clay-700">
              <Icon name="sparkle" class="h-3.5 w-3.5" /> Beliebteste Wahl
            </span>
          )}
          <span class="inline-flex items-center gap-1.5 rounded-full border border-petrol-200 bg-white/70 px-3 py-1 text-xs font-medium text-petrol-700">
            <Icon name="clock" class="h-3.5 w-3.5" strokeWidth={2} /> {pkg.meta}
          </span>
        </div>
        <h1 class="mt-4 font-serif text-4xl text-petrol-900 sm:text-5xl">{pkg.name}</h1>
        <p class="prose-lead mt-4">{pkg.tagline}</p>
      </div>
    </div>
  </section>

  <!-- ===================== HAUPTINHALT ===================== -->
  <section class="mx-auto grid max-w-7xl items-start gap-12 px-4 py-16 sm:px-6 lg:grid-cols-5 lg:px-8">
    <div class="lg:col-span-3">
      <p class="reveal leading-relaxed text-sand-700">{pkg.content}</p>

      <div class="reveal mt-10">
        <h2 class="font-serif text-2xl text-petrol-900">Das ist enthalten</h2>
        <ul class="mt-5 grid gap-3 sm:grid-cols-2">
          {
            pkg.features.map((f) => (
              <li class="flex items-start gap-3 rounded-xl border border-sand-200 bg-white p-4 text-sand-700">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-petrol-100 text-petrol-600">
                  <Icon name="check" class="h-3.5 w-3.5" strokeWidth={3} />
                </span>
                <span class="text-sm">{f}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="reveal mt-10 rounded-2xl border border-clay-200 bg-clay-50/60 p-6">
        <h2 class="flex items-center gap-2 font-serif text-xl text-petrol-900">
          <Icon name="heart" class="h-5 w-5 text-clay-600" /> Für wen passt das?
        </h2>
        <p class="mt-3 leading-relaxed text-sand-700">{pkg.forWhom}</p>
      </div>

      <div class="reveal mt-10">
        <h2 class="font-serif text-2xl text-petrol-900">So läuft es ab</h2>
        <ol class="mt-5 space-y-4">
          {
            flow.map((s, i) => (
              <li class="flex items-start gap-4">
                <span class="relative flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-petrol-100 text-petrol-600">
                  <Icon name={s.icon} class="h-5 w-5" />
                  <span class="absolute -right-1 -top-1 flex h-5 w-5 items-center justify-center rounded-full bg-clay-500 font-serif text-[0.65rem] text-white ring-2 ring-sand-50">
                    {i + 1}
                  </span>
                </span>
                <div>
                  <h3 class="font-serif text-lg text-petrol-900">{s.t}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-sand-600">{s.d}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <!-- Sticky Buchungs-Box -->
    <aside class="lg:col-span-2 lg:sticky lg:top-28">
      <div class="overflow-hidden rounded-2xl border border-sand-200 bg-white shadow-sm">
        <Image
          src={boxImg}
          alt="Morpheus – gesund und ausgeglichen"
          widths={[400, 640]}
          sizes="(max-width: 1024px) 100vw, 40vw"
          loading="lazy"
          class="w-full h-auto"
        />
        <div class="p-7">
          <p class="font-serif text-2xl text-petrol-800">{pkg.name}</p>
          <p class="mt-1 text-sm text-sand-500">{pkg.meta} · online · weltweit</p>
          <div class="mt-6 flex flex-col gap-3">
            <Button href={whatsappLink(prefill)} variant="primary" size="lg" external class="wag-hover group">
              <Icon name="paw" class="wag h-5 w-5" />
              Termin anfragen
            </Button>
          </div>
          <ul class="mt-6 space-y-2.5 border-t border-sand-100 pt-5 text-sm text-sand-600">
            <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-petrol-500" strokeWidth={3} /> Unverbindlich – erst schauen wir, ob es passt</li>
            <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-petrol-500" strokeWidth={3} /> Persönliche Antwort von Selin</li>
            <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-petrol-500" strokeWidth={3} /> Zusammenfassung im Anschluss</li>
          </ul>
        </div>
      </div>
    </aside>
  </section>

  <!-- ===================== WEITERE PAKETE ===================== -->
  <section class="bg-petrol-50/60 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Vergleichen</p>
        <h2 class="mt-2 font-serif text-2xl text-petrol-900 sm:text-3xl">Weitere Pakete</h2>
      </div>
      <div class="stagger mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          others.map((p) => (
            <a
              href={`/angebot/${p.slug}`}
              class="reveal lift group flex flex-col rounded-2xl border border-sand-200 bg-white p-6 shadow-sm hover:border-petrol-200 hover:shadow-md"
            >
              <span class="text-xs font-medium text-sand-500">{p.meta}</span>
              <h3 class="mt-1 font-serif text-lg text-petrol-900 group-hover:text-petrol-700">{p.name}</h3>
              <p class="mt-1 flex-1 text-sm text-sand-500">{p.tagline}</p>
              <p class="mt-4 flex items-center justify-between text-sm font-medium text-petrol-700">
                Details ansehen
                <Icon name="arrowRight" class="h-4 w-4 text-clay-500 transition-transform group-hover:translate-x-1" strokeWidth={2} />
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="py-24">
    <CtaBanner />
  </div>
</BaseLayout>
