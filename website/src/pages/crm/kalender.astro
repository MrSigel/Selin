---
import CrmLayout from "../../layouts/CrmLayout.astro";
---
<CrmLayout title="Kalender" active="kalender">
  <div id="crm-root"></div>
</CrmLayout>

<script>
  import { mountResource } from "../../lib/crm-ui";
  mountResource({
    table: "termine",
    singular: "Termin",
    order: "start_at",
    asc: true,
    defaults: { location: "Online", status: "geplant" },
    emptyText: "Noch keine Termine.",
    columns: [
      { key: "title", label: "Titel" },
      { key: "start_at", label: "Beginn", type: "datetime" },
      { key: "location", label: "Ort" },
      { key: "status", label: "Status", type: "badge" },
    ],
    fields: [
      { key: "title", label: "Titel", required: true },
      { key: "start_at", label: "Beginn", type: "datetime", required: true },
      { key: "end_at", label: "Ende", type: "datetime" },
      { key: "location", label: "Ort" },
      { key: "status", label: "Status", type: "select", options: [
        { value: "geplant", label: "Geplant" },
        { value: "bestätigt", label: "Bestätigt" },
        { value: "abgesagt", label: "Abgesagt" },
        { value: "erledigt", label: "Erledigt" },
      ] },
      { key: "notes", label: "Notizen", type: "textarea" },
    ],
  });
</script>
