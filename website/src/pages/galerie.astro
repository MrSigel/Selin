---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { site } from "../data/site";

const title = "Galerie – Momente aus der Begleitung";
const description =
  "Bilder und kleine Geschichten aus der ganzheitlichen Hundegesundheits-Begleitung von Selin Weikard – echte Wege, echte Hunde, echte Veränderung.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: "Galerie – Selin Weikard",
  description,
  url: `${site.domain}/galerie`,
};
---
<BaseLayout title={title} description={description} path="/galerie" schema={schema}>
  <section class="relative overflow-hidden bg-gradient-to-b from-petrol-50 to-sand-50">
    <Icon name="paw" class="paw-deco pointer-events-none absolute -right-6 top-8 h-32 w-32 text-clay-300/20" />
    <div class="relative mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:py-20 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Galerie</p>
      <h1 class="mt-3 font-serif text-4xl text-petrol-900 sm:text-5xl">Momente, die den Weg erzählen</h1>
      <p class="prose-lead mx-auto mt-6 max-w-2xl">
        Kleine Einblicke in echte Begleitungen – jedes Bild mit einer kurzen Geschichte dahinter.
        Weil Veränderung nicht in Zahlen sichtbar wird, sondern in Momenten.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div id="galerie-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"></div>

    <!-- Seitensteuerung -->
    <nav id="galerie-pager" class="mt-12 hidden flex-wrap items-center justify-center gap-2" aria-label="Galerie-Seiten"></nav>
  </section>

  <div class="pb-4">
    <CtaBanner
      title="Auch dein Hund hat eine Geschichte"
      text="Wenn du spürst, dass mehr dahintersteckt, lass uns gemeinsam auf die Ursache schauen."
    />
  </div>
</BaseLayout>

<script>
  import { galeriePhotos } from "../data/galerie";
  import { listPublicGalerie, escapeHtml } from "../lib/db";

  const PER_PAGE = 12;
  const grid = document.getElementById("galerie-grid")!;
  const pager = document.getElementById("galerie-pager")!;

  type Item = { src: string; text: string };

  function card(item: Item) {
    const story = item.text
      ? `<figcaption class="p-5 text-sm leading-relaxed text-sand-600">${escapeHtml(item.text)}</figcaption>`
      : "";
    return `
      <figure class="group overflow-hidden rounded-2xl border border-sand-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-lg">
        <div class="aspect-[4/3] w-full overflow-hidden">
          <img src="${escapeHtml(item.src)}" alt="" loading="lazy"
               class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
        </div>
        ${story}
      </figure>`;
  }

  let items: Item[] = [];
  let page = 1;

  function pages() { return Math.max(1, Math.ceil(items.length / PER_PAGE)); }

  function renderPage() {
    const total = pages();
    page = Math.min(Math.max(1, page), total);
    const start = (page - 1) * PER_PAGE;
    grid.innerHTML = items.slice(start, start + PER_PAGE).map(card).join("");

    if (total <= 1) { pager.classList.add("hidden"); return; }
    pager.classList.remove("hidden");
    pager.classList.add("flex");
    const btn = (label: string, target: number, disabled: boolean, active = false) =>
      `<button data-page="${target}" ${disabled ? "disabled" : ""}
        class="min-w-10 rounded-full px-4 py-2 text-sm font-medium transition-colors ${
          active ? "bg-clay-600 text-white"
          : disabled ? "cursor-not-allowed text-sand-400"
          : "border border-sand-300 text-petrol-800 hover:border-petrol-300 hover:bg-white"}">${label}</button>`;
    let html = btn("←", page - 1, page === 1);
    for (let p = 1; p <= total; p++) html += btn(String(p), p, false, p === page);
    html += btn("→", page + 1, page === total);
    pager.innerHTML = html;
    pager.querySelectorAll<HTMLButtonElement>("button[data-page]").forEach((b) => {
      b.addEventListener("click", () => {
        page = Number(b.dataset.page);
        renderPage();
        document.getElementById("galerie-grid")?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
  }

  (async () => {
    // Statische Fotos als Basis
    items = [...galeriePhotos];
    renderPage();
    // Vom CRM hinzugefügte Bilder vorne anfügen (Duplikate der festen Auswahl ausschließen)
    try {
      const staticSrcs = new Set(galeriePhotos.map((p) => p.src));
      const crm = (await listPublicGalerie())
        .map((c) => ({ src: c.bild_url, text: c.geschichte || "" }))
        .filter((c) => c.src && !staticSrcs.has(c.src));
      if (crm.length) {
        items = [...crm, ...galeriePhotos];
        renderPage();
      }
    } catch { /* Tabelle evtl. noch nicht angelegt – statische Fotos genügen */ }
  })();
</script>
