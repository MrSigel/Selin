---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { academyBenefits, academyModules, whatsappLink, site } from "../data/site";
import warumImg from "../assets/morpheus-6.jpeg";

const title = "Academy – ganzheitliche Hundegesundheit lernen";
const description =
  "Die Online-Academy von Selin Weikard: 7 Module zu Ernährung, Nahrungsergänzung und Homöopathie. Mitgliedschaft ab 29,99 €/Monat mit Live-Call, Podcast und Community.";

const moduleIcons = ["compass", "bowl", "leaf", "sparkle", "target", "shield", "handHeart"];

const bonus = [
  "PDF-Checklisten & Symptombögen",
  "Rezeptsammlung & Einkaufslisten",
  "Portionsrechner-Vorlage",
  "Homöopathische Mittel-Übersichtskarten",
  "Private Community-Gruppe",
  "Gesundheitstagebuch als Vorlage",
  "Monatlicher Kompetenz-Call (live)",
  "Podcast-Archiv „Drei Perspektiven, ein Hund“",
  "Teilnahmezertifikat nach Abschluss",
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Course",
    name: "Ganzheitliche Hundegesundheit: Natürlich heilen mit Ernährung, Supplements & Homöopathie",
    description:
      "Strukturierter Onlinekurs in 7 Modulen: von den Grundlagen der ganzheitlichen Hundegesundheit über Ernährung und Nahrungsergänzung bis zu Homöopathie und langfristiger Betreuung.",
    provider: { "@id": `${site.domain}/#organization` },
    inLanguage: "de",
    offers: {
      "@type": "Offer",
      price: 29.99,
      priceCurrency: "EUR",
      category: "Subscription",
      url: `${site.domain}/academy`,
    },
    hasCourseInstance: {
      "@type": "CourseInstance",
      courseMode: "online",
      courseWorkload: "P7M",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: site.domain },
      { "@type": "ListItem", position: 2, name: "Academy", item: `${site.domain}/academy` },
    ],
  },
];
---
<BaseLayout title={title} description={description} path="/academy" schema={schema}>
  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-petrol-700 to-petrol-900 text-sand-100">
    <div class="pointer-events-none absolute -left-32 top-0 h-96 w-96 rounded-full bg-petrol-600/30 blur-3xl"></div>
    <Icon name="paw" class="paw-deco pointer-events-none absolute bottom-6 left-1/3 h-40 w-40 text-white/[0.04]" />
    <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24 lg:px-8">
      <div class="reveal is-visible">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-300">Academy</p>
        <h1 class="mt-3 font-serif text-4xl leading-[1.08] text-white sm:text-5xl">
          Werde selbst zur Expertin für deinen Hund
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-sand-100/85">
          Nicht als Ersatz für den Tierarzt, sondern als mündiger, aufmerksamer Begleiter, der weiß,
          wann ein Arztbesuch wirklich nötig ist – und wann der eigene Blick genügt. Mein Wissen,
          strukturiert und jederzeit abrufbar.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={whatsappLink("Hallo Selin, ich interessiere mich für die Academy-Mitgliedschaft.")} variant="primary" size="lg" external class="wag-hover group">
            <Icon name="paw" class="wag h-5 w-5" />
            Mitglied werden
          </Button>
          <Button href="#module" variant="white" size="lg" class="group">
            Kursinhalte ansehen
            <Icon name="arrowRight" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" strokeWidth={2} />
          </Button>
        </div>
      </div>
      <div class="reveal is-visible rounded-3xl border border-white/10 bg-white/10 p-8 backdrop-blur-sm">
        <p class="font-serif text-5xl text-white">29,99 €<span class="text-xl text-sand-100/70"> / Monat</span></p>
        <p class="mt-2 text-sm text-sand-100/70">Jederzeit kündbar · lebenslanger Zugang, solange die Mitgliedschaft läuft</p>
        <ul class="mt-6 space-y-4">
          {
            academyBenefits.map((b) => (
              <li class="flex gap-3">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-clay-500/25 text-clay-200">
                  <Icon name="check" class="h-3.5 w-3.5" strokeWidth={3} />
                </span>
                <span>
                  <span class="font-medium text-white">{b.title}</span>
                  <span class="block text-sm text-sand-100/75">{b.text}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== WARUM ===================== -->
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="reveal">
        <div class="mx-auto max-w-sm overflow-hidden rounded-[1.75rem] border-[6px] border-white shadow-2xl lg:max-w-none">
          <Image
            src={warumImg}
            alt="Morpheus entspannt – Lernen im eigenen Tempo"
            widths={[480, 768]}
            sizes="(max-width: 1024px) 100vw, 45vw"
            loading="lazy"
            class="aspect-[4/3] w-full object-cover"
            style="object-position: center 30%;"
          />
        </div>
      </div>
      <div class="reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Warum eine Academy?</p>
        <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">Wissen, das nicht an meiner Zeit hängt</h2>
        <p class="mt-5 leading-relaxed text-sand-700">
          1:1-Sitzungen sind zeitlich begrenzt. Die Academy löst diese Grenze auf: Ein einmal
          produzierter Kurs steht beliebig vielen Hundehaltern gleichzeitig zur Verfügung – weltweit,
          ohne dass die Qualität leidet.
        </p>
        <ul class="mt-6 space-y-3">
          {
            [
              "Du lernst in deinem Tempo und kannst jederzeit nachschlagen.",
              "Alles strukturiert – von den Grundlagen bis zur Praxis.",
              "Ein guter Einstieg, bevor du dich für eine 1:1-Begleitung entscheidest.",
            ].map((t) => (
              <li class="flex gap-3 text-sand-700">
                <Icon name="check" class="mt-1 h-4 w-4 shrink-0 text-petrol-500" strokeWidth={3} />
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== MODULE ===================== -->
  <section id="module" class="bg-gradient-to-b from-sand-50 to-petrol-50/40 py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="reveal text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Der Kurs</p>
        <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">Ganzheitliche Hundegesundheit in 7 Modulen</h2>
        <p class="mt-4 text-lg text-sand-600">Natürlich heilen mit Ernährung, Supplements &amp; Homöopathie.</p>
      </div>
      <div class="stagger mt-12 space-y-4">
        {
          academyModules.map((m, i) => (
            <div class="reveal group flex items-start gap-5 rounded-2xl border border-sand-200 bg-white p-6 transition-all duration-200 hover:-translate-y-1 hover:border-petrol-200 hover:shadow-md">
              <span class="relative flex h-14 w-14 shrink-0 items-center justify-center">
                <span class="icon-chip flex h-14 w-14 bg-petrol-600 text-white">
                  <Icon name={moduleIcons[i]} class="h-7 w-7" />
                </span>
                <span class="absolute -right-1 -top-1 flex h-6 w-6 items-center justify-center rounded-full bg-clay-500 font-serif text-xs text-white ring-4 ring-sand-50">
                  {m.n}
                </span>
              </span>
              <div>
                <h3 class="font-serif text-lg text-petrol-900">{m.title}</h3>
                <p class="mt-1.5 leading-relaxed text-sand-600">{m.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== BONUS ===================== -->
  <section class="mx-auto max-w-5xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="reveal text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Immer dabei</p>
      <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">Inklusive in der Mitgliedschaft</h2>
    </div>
    <div class="stagger mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        bonus.map((b) => (
          <div class="reveal flex items-center gap-3 rounded-xl border border-sand-200 bg-white p-4 text-sand-700 transition-colors hover:border-petrol-200">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-petrol-100 text-petrol-600">
              <Icon name="check" class="h-3.5 w-3.5" strokeWidth={3} />
            </span>
            <span class="text-sm">{b}</span>
          </div>
        ))
      }
    </div>
  </section>

  <div class="pb-24">
    <CtaBanner
      title="Bereit, tiefer einzusteigen?"
      text="Werde Academy-Mitglied und lerne, deinen Hund wirklich zu verstehen – Schritt für Schritt, in deinem Tempo."
    />
  </div>
</BaseLayout>
