---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Disclaimer from "../components/Disclaimer.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { academyBenefits, academyModules, whatsappLink, site } from "../data/site";

const title = "Academy – ganzheitliche Hundegesundheit lernen";
const description =
  "Die Online-Academy von Selin Weikard: 7 Module zu Ernährung, Nahrungsergänzung und Homöopathie. Mitgliedschaft ab 29,99 €/Monat mit Live-Call, Podcast und Community.";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Course",
    name: "Ganzheitliche Hundegesundheit: Natürlich heilen mit Ernährung, Supplements & Homöopathie",
    description:
      "Strukturierter Onlinekurs in 7 Modulen: von den Grundlagen der ganzheitlichen Hundegesundheit über Ernährung und Nahrungsergänzung bis zu Homöopathie und langfristiger Betreuung.",
    provider: { "@id": `${site.domain}/#organization` },
    inLanguage: "de",
    offers: {
      "@type": "Offer",
      price: 29.99,
      priceCurrency: "EUR",
      category: "Subscription",
      url: `${site.domain}/academy`,
    },
    hasCourseInstance: {
      "@type": "CourseInstance",
      courseMode: "online",
      courseWorkload: "P7M",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: site.domain },
      { "@type": "ListItem", position: 2, name: "Academy", item: `${site.domain}/academy` },
    ],
  },
];
---
<BaseLayout title={title} description={description} path="/academy" schema={schema}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-petrol-700 to-petrol-900 text-sand-100">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24 lg:px-8">
      <div class="reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-300">Academy</p>
        <h1 class="mt-3 font-serif text-4xl text-white sm:text-5xl">
          Werde selbst zur Expertin für deinen Hund
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-sand-100/85">
          Nicht als Ersatz für den Tierarzt, sondern als mündiger, aufmerksamer Begleiter, der weiß,
          wann ein Arztbesuch wirklich nötig ist – und wann der eigene Blick genügt. Mein Wissen,
          strukturiert und jederzeit abrufbar.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={whatsappLink("Hallo Selin, ich interessiere mich für die Academy-Mitgliedschaft.")} variant="primary" size="lg" external>
            Mitglied werden
          </Button>
          <Button href="#module" variant="white" size="lg">Kursinhalte ansehen</Button>
        </div>
      </div>
      <div class="reveal rounded-2xl bg-white/10 p-8 backdrop-blur-sm">
        <p class="font-serif text-5xl text-white">29,99 €<span class="text-xl text-sand-100/70"> / Monat</span></p>
        <p class="mt-2 text-sm text-sand-100/70">Jederzeit kündbar · lebenslanger Zugang, solange die Mitgliedschaft läuft</p>
        <ul class="mt-6 space-y-3.5">
          {academyBenefits.map((b) => (
            <li class="flex gap-3">
              <span class="mt-1 text-clay-300">✓</span>
              <span>
                <span class="font-medium text-white">{b.title}</span>
                <span class="block text-sm text-sand-100/75">{b.text}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Warum -->
  <section class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:px-8">
    <div class="reveal">
      <h2 class="font-serif text-3xl text-petrol-900 sm:text-4xl">Warum eine Academy?</h2>
      <p class="prose-lead mx-auto mt-5 max-w-2xl">
        1:1-Sitzungen sind zeitlich begrenzt. Die Academy löst diese Grenze auf: Ein einmal
        produzierter Kurs steht beliebig vielen Hundehaltern gleichzeitig zur Verfügung – weltweit,
        ohne dass die Qualität leidet. Du lernst in deinem Tempo und kannst jederzeit nachschlagen.
      </p>
    </div>
  </section>

  <!-- Module -->
  <section id="module" class="bg-sand-100 py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="reveal text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Der Kurs</p>
        <h2 class="mt-2 font-serif text-3xl text-petrol-900 sm:text-4xl">
          Ganzheitliche Hundegesundheit in 7 Modulen
        </h2>
        <p class="mt-4 text-lg text-sand-600">
          Natürlich heilen mit Ernährung, Supplements &amp; Homöopathie.
        </p>
      </div>
      <div class="stagger mt-12 space-y-4">
        {academyModules.map((m) => (
          <div class="reveal group flex gap-5 rounded-2xl border border-sand-200 bg-white p-6 transition-all duration-200 hover:-translate-y-1 hover:border-petrol-200 hover:shadow-md">
            <span class="icon-chip flex h-11 w-11 shrink-0 bg-petrol-100 font-serif text-lg font-medium text-petrol-700">
              {m.n}
            </span>
            <div>
              <h3 class="font-serif text-lg text-petrol-900">Modul {m.n}: {m.title}</h3>
              <p class="mt-1.5 leading-relaxed text-sand-600">{m.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bonus -->
  <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="reveal text-center">
      <h2 class="font-serif text-3xl text-petrol-900 sm:text-4xl">Inklusive in der Mitgliedschaft</h2>
    </div>
    <div class="stagger mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        [
          "PDF-Checklisten & Symptombögen",
          "Rezeptsammlung & Einkaufslisten",
          "Portionsrechner-Vorlage",
          "Homöopathische Mittel-Übersichtskarten",
          "Private Community-Gruppe",
          "Gesundheitstagebuch als Vorlage",
          "Monatlicher Kompetenz-Call (live)",
          "Podcast-Archiv „Drei Perspektiven, ein Hund“",
          "Teilnahmezertifikat nach Abschluss",
        ].map((b) => (
          <div class="reveal flex items-center gap-3 rounded-xl border border-sand-200 bg-white p-4 text-sand-700">
            <span class="text-petrol-500">✓</span>
            <span class="text-sm">{b}</span>
          </div>
        ))
      }
    </div>
    <div class="reveal mx-auto mt-12 max-w-3xl">
      <Disclaimer />
    </div>
  </section>

  <div class="pb-24">
    <CtaBanner
      title="Bereit, tiefer einzusteigen?"
      text="Werde Academy-Mitglied und lerne, deinen Hund wirklich zu verstehen – Schritt für Schritt, in deinem Tempo."
    />
  </div>
</BaseLayout>
