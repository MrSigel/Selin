---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { methodSteps, whatsappLink, site } from "../data/site";
import heroImg from "../assets/morpheus-3.jpeg";
import haltungImg from "../assets/morpheus-2.jpeg";

const title = "Die Methode: Ursache statt Symptom";
const description =
  "Der ganzheitliche Ansatz von Selin Weikard: In fünf Schritten von der Anamnese zur eigentlichen Ursache. Körper, Ernährung und Verhalten deines Hundes zusammen betrachtet.";

// Die vier Säulen des ganzheitlichen Blicks
const pillars = [
  {
    icon: "bowl",
    t: "Ernährung",
    d: "Was täglich in den Napf kommt – und wie gut der Körper es wirklich verträgt. Oft die stille Wurzel vieler Beschwerden.",
  },
  {
    icon: "shield",
    t: "Darm & Immunsystem",
    d: "Der Großteil der Abwehr sitzt im Darm. Ist er im Ungleichgewicht, zeigt sich das an Haut, Fell, Energie und Verhalten.",
  },
  {
    icon: "bone",
    t: "Körper & Gelenke",
    d: "Blockaden, Verspannungen oder Schmerzen, die der Hund nicht zeigt – bei Bedarf mit Weiterempfehlung an einen Tier-Chiropraktiker.",
  },
  {
    icon: "activity",
    t: "Nervensystem & Verhalten",
    d: "Unruhe, Angst oder Rückzug als Signal ernst nehmen – nicht als bloßes Erziehungsthema abtun.",
  },
];

const fitYes = [
  "Du hast schon vieles probiert, aber niemand hat die Ursache gefunden.",
  "Du bist bereit, ganzheitlich auf deinen Hund zu schauen.",
  "Du willst Zeit und Liebe in echte Veränderung investieren.",
  "Du möchtest verstehen, was wirklich los ist – statt nur ein weiteres Mittel.",
];
const fitNo = [
  "Du suchst eine schnelle Pille ohne jede Umstellung.",
  "Dein Hund hat einen akuten Notfall (dann bitte sofort zum Tierarzt).",
  "Du möchtest, dass jemand die Verantwortung komplett abnimmt.",
  "Du möchtest an Ernährung oder Alltag nichts verändern.",
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "Ganzheitliche Hundegesundheit: In fünf Schritten zur Ursache",
    description:
      "So läuft eine ganzheitliche Begleitung bei Selin Weikard ab – von der Anamnese bis zur langfristigen Begleitung.",
    step: methodSteps.map((s, i) => ({
      "@type": "HowToStep",
      position: i + 1,
      name: s.title,
      text: s.text,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: site.domain },
      { "@type": "ListItem", position: 2, name: "Methode", item: `${site.domain}/methode` },
    ],
  },
];
---
<BaseLayout title={title} description={description} path="/methode" schema={schema}>
  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden bg-gradient-to-b from-petrol-50 via-sand-50 to-sand-50">
    <div class="pointer-events-none absolute -right-24 top-0 h-96 w-96 rounded-full bg-petrol-100/60 blur-3xl"></div>
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24 lg:px-8">
      <div class="reveal is-visible">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Die Methode</p>
        <h1 class="mt-3 font-serif text-4xl leading-[1.08] text-petrol-900 sm:text-5xl lg:text-[3.4rem]">
          Ursache statt Symptom
        </h1>
        <p class="prose-lead mt-6 max-w-xl">
          Jeder Hund kann gesünder, ausgeglichener und glücklicher werden – wenn man aufhört, nur
          Symptome zu behandeln, und anfängt, die eigentliche <strong class="text-petrol-800">Ursache</strong>
          zu finden. Diese Haltung trägt meine gesamte Arbeit.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={whatsappLink()} variant="primary" size="lg" external class="wag-hover group">
            <Icon name="paw" class="wag h-5 w-5" />
            Termin anfragen
          </Button>
          <Button href="#ablauf" variant="ghost" size="lg" class="group">
            Die 5 Schritte ansehen
            <Icon name="arrowRight" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" strokeWidth={2} />
          </Button>
        </div>
      </div>
      <div class="reveal is-visible">
        <div class="relative">
          <Image
            src={heroImg}
            alt="Ruhige Nahaufnahme von Morpheus – aufmerksamer Blick"
            widths={[480, 768, 1024]}
            sizes="(max-width: 1024px) 100vw, 45vw"
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto rounded-2xl shadow-xl"
          />
          <div class="absolute -bottom-5 -left-5 hidden items-center gap-3 rounded-2xl border border-sand-200 bg-white p-4 shadow-lg sm:flex">
            <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-petrol-100 text-petrol-600">
              <Icon name="search" class="h-6 w-6" />
            </span>
            <span class="max-w-[10rem] text-sm text-sand-700">
              Wir schauen dorthin, wo vorher niemand hingeschaut hat.
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== ZWEI KERNFRAGEN ===================== -->
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Der Ausgangspunkt</p>
      <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">Zwei Fragen, die alles verändern</h2>
    </div>
    <div class="stagger mt-12 grid gap-6 md:grid-cols-2">
      <div class="reveal lift group rounded-2xl border border-sand-200 bg-white p-8 hover:border-petrol-200 hover:shadow-lg">
        <span class="icon-chip mb-5 flex h-12 w-12 bg-petrol-100 text-petrol-600">
          <Icon name="search" class="h-6 w-6" />
        </span>
        <h3 class="font-serif text-2xl text-petrol-900">Warum findet niemand die Ursache?</h3>
        <p class="mt-4 leading-relaxed text-sand-700">
          Viele Hunde werden behandelt, ohne dass sich wirklich etwas verändert – oder der Tierarzt
          findet nichts Eindeutiges. Der Grund: Beschwerden zeigen sich oft erst im Zusammenspiel von
          Ernährung, Darm, Immunsystem und Nervensystem. Wer nur einzelne Symptome betrachtet,
          übersieht die Verbindung dahinter.
        </p>
      </div>
      <div class="reveal lift group rounded-2xl border border-sand-200 bg-white p-8 hover:border-petrol-200 hover:shadow-lg">
        <span class="icon-chip mb-5 flex h-12 w-12 bg-clay-100 text-clay-600">
          <Icon name="heart" class="h-6 w-6" />
        </span>
        <h3 class="font-serif text-2xl text-petrol-900">Wie hängen Körper und Verhalten zusammen?</h3>
        <p class="mt-4 leading-relaxed text-sand-700">
          Viele „Verhaltensprobleme“ haben eine gesundheitliche Wurzel: Blockaden, Unverträglichkeiten
          oder Schmerzen, die der Hund nicht zeigen kann. Unruhe, Aggression, Ängstlichkeit oder
          Rückzug sind dann kein reines Erziehungsthema. Genau diese beiden Themen denke ich bewusst
          zusammen.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== DER GANZHEITLICHE BLICK (Säulen) ===================== -->
  <section class="relative overflow-hidden bg-petrol-900 py-24 text-sand-100">
    <div class="pointer-events-none absolute -left-32 top-1/4 h-96 w-96 rounded-full bg-petrol-700/30 blur-3xl"></div>
    <Icon name="paw" class="paw-deco pointer-events-none absolute bottom-8 right-8 h-44 w-44 text-white/[0.03]" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-300">Der ganzheitliche Blick</p>
        <h2 class="mt-3 font-serif text-3xl text-white sm:text-4xl">Vier Bereiche, die ineinandergreifen</h2>
        <p class="mt-4 text-lg leading-relaxed text-sand-100/75">
          Weil ein Hund kein Baukasten aus Einzelteilen ist. Erst im Zusammenspiel wird sichtbar, was
          einzeln betrachtet übersehen wird.
        </p>
      </div>
      <div class="stagger mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          pillars.map((p) => (
            <div class="reveal lift group rounded-2xl border border-petrol-700/50 bg-petrol-800/40 p-6 transition-colors hover:border-clay-400/40 hover:bg-petrol-800/70">
              <span class="icon-chip flex h-12 w-12 bg-clay-500/20 text-clay-200">
                <Icon name={p.icon} class="h-6 w-6" />
              </span>
              <h3 class="mt-4 font-serif text-lg text-white">{p.t}</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand-100/70">{p.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== DIE 5 SCHRITTE (vertikale Timeline) ===================== -->
  <section id="ablauf" class="relative overflow-hidden bg-gradient-to-b from-sand-50 to-petrol-50/40 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">So läuft eine Begleitung ab</p>
        <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">In fünf Schritten zur Ursache</h2>
        <p class="mt-4 text-lg leading-relaxed text-sand-600">
          Ein klarer Weg – vom ersten Gespräch bis zur langfristigen Stabilität deines Hundes.
        </p>
      </div>

      <div class="relative mx-auto mt-14 max-w-3xl">
        <div
          class="absolute left-7 top-6 bottom-6 w-0.5 bg-gradient-to-b from-petrol-200 via-petrol-300 to-clay-300 sm:left-8"
          aria-hidden="true"
        >
        </div>
        <ol class="stagger space-y-6">
          {
            methodSteps.map((step, i) => (
              <li class="reveal group flex items-stretch gap-5 sm:gap-6">
                <span class="relative z-10 flex h-14 w-14 shrink-0 items-center justify-center rounded-full border-2 border-petrol-200 bg-white text-petrol-600 shadow-sm transition-all duration-300 group-hover:border-petrol-600 group-hover:bg-petrol-600 group-hover:text-white sm:h-16 sm:w-16">
                  <Icon name={step.icon} class="h-7 w-7" />
                  <span class="absolute -right-1 -top-1 flex h-6 w-6 items-center justify-center rounded-full bg-clay-500 font-serif text-xs text-white ring-4 ring-sand-50">
                    {i + 1}
                  </span>
                </span>
                <div class="flex-1 rounded-2xl border border-sand-200 bg-white p-6 shadow-sm transition-all duration-200 group-hover:-translate-y-0.5 group-hover:border-petrol-200 group-hover:shadow-md">
                  <h3 class="font-serif text-xl text-petrol-900">{step.title}</h3>
                  <p class="mt-2 leading-relaxed text-sand-700">{step.text}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- ===================== HALTUNG / ZITAT ===================== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-clay-50 via-sand-100 to-clay-100/60 py-24">
    <Icon name="paw" class="paw-deco pointer-events-none absolute -left-8 bottom-10 h-40 w-40 text-clay-300/25" />
    <div class="relative mx-auto grid max-w-7xl items-center gap-14 px-4 sm:px-6 lg:grid-cols-12 lg:px-8">
      <div class="reveal lg:col-span-5">
        <div class="mx-auto max-w-sm overflow-hidden rounded-[1.75rem] border-[6px] border-white shadow-2xl lg:max-w-none">
          <Image
            src={haltungImg}
            alt="Morpheus wach und lebensfroh auf der Wiese"
            widths={[480, 768]}
            sizes="(max-width: 1024px) 100vw, 40vw"
            loading="lazy"
            class="w-full h-auto"
          />
        </div>
      </div>
      <div class="reveal lg:col-span-7">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Meine Haltung</p>
        <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">Keine Zufälle – nur Ursachen</h2>
        <p class="mt-5 leading-relaxed text-sand-700">
          Beschwerden beim Hund sind keine zufälligen Störungen, sondern Signale eines Systems, das
          nach Gleichgewicht sucht. Wer das versteht, hört auf, Symptome zu jagen – und fängt an,
          Ursachen zu finden.
        </p>
        <p class="mt-4 leading-relaxed text-sand-700">
          Ich bin kein Gegner der Schulmedizin. Natürliche Methoden sind der erste Weg, nicht der
          einzige. Bei echten Notfällen bleibt die Tierärztin oder der Tierarzt die erste Anlaufstelle.
        </p>
        <figure class="mt-8 rounded-2xl bg-white/70 p-6 shadow-sm ring-1 ring-clay-100">
          <Icon name="sparkle" class="h-6 w-6 text-clay-400" />
          <blockquote class="mt-2 font-serif text-xl italic leading-relaxed text-petrol-800">
            Es gibt keine Zufälle. Alles passiert aus einem bestimmten Grund.
          </blockquote>
          <figcaption class="mt-3 text-sm font-medium text-clay-700">— Selin Weikard</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ===================== FÜR WEN ===================== -->
  <section class="mx-auto max-w-5xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Ehrlich gesagt</p>
      <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">Für wen ist das gedacht?</h2>
    </div>
    <div class="stagger mt-12 grid gap-6 md:grid-cols-2">
      <div class="reveal rounded-2xl border border-petrol-100 bg-white p-7 shadow-sm">
        <h3 class="flex items-center gap-2 font-serif text-lg text-petrol-900">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-petrol-100 text-petrol-600">
            <Icon name="check" class="h-4 w-4" strokeWidth={3} />
          </span>
          Passt, wenn du …
        </h3>
        <ul class="mt-5 space-y-3.5 text-sand-700">
          {
            fitYes.map((t) => (
              <li class="flex gap-3">
                <Icon name="check" class="mt-1 h-4 w-4 shrink-0 text-petrol-500" strokeWidth={3} />
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="reveal rounded-2xl border border-sand-200 bg-white p-7 shadow-sm">
        <h3 class="flex items-center gap-2 font-serif text-lg text-petrol-900">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-clay-100 text-clay-600">
            <Icon name="x" class="h-4 w-4" strokeWidth={2.5} />
          </span>
          Passt (noch) nicht, wenn du …
        </h3>
        <ul class="mt-5 space-y-3.5 text-sand-600">
          {
            fitNo.map((t) => (
              <li class="flex gap-3">
                <Icon name="x" class="mt-1 h-4 w-4 shrink-0 text-clay-400" strokeWidth={2.5} />
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <div class="pb-24">
    <CtaBanner title="Lass uns die Ursache finden" />
  </div>
</BaseLayout>
