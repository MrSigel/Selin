---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { site, whatsappLink } from "../data/site";

const title = "Podcast „Drei Perspektiven, ein Hund“";
const description =
  "Der Podcast von Selin Weikard: Tierärztin, Tier-Chiropraktiker und Selin betrachten denselben Hund aus drei Blickwinkeln – für ein vollständigeres Bild von Hundegesundheit.";

const perspectives = [
  {
    role: "Die Tierärztin",
    icon: "stethoscope",
    text: "Bringt die tierärztliche, schulmedizinische Perspektive ein – für eine fundierte Einordnung und klare Grenzen.",
    chip: "bg-petrol-100 text-petrol-600",
  },
  {
    role: "Der Tier-Chiropraktiker",
    icon: "bone",
    text: "Steuert die körperliche, chiropraktische Sicht bei – Blockaden, Bewegungsapparat und ihre oft unterschätzte Rolle.",
    chip: "bg-clay-100 text-clay-600",
  },
  {
    role: "Selin Weikard",
    icon: "leaf",
    text: "Die ganzheitliche Ursachen-Perspektive aus Homöopathie, Ernährung und drei Jahren echter Erfahrung.",
    chip: "bg-petrol-100 text-petrol-600",
  },
];

const format = [
  { icon: "users", t: "Ein typischer, anonymisierter Fall pro Folge" },
  { icon: "microphone", t: "Drei echte Experten statt einer Meinung" },
  { icon: "clock", t: "Erscheint regelmäßig (geplant: monatlich)" },
  { icon: "book", t: "Für Academy-Mitglieder im vollständigen Archiv" },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "PodcastSeries",
  name: "Drei Perspektiven, ein Hund",
  description: description,
  url: `${site.domain}/podcast`,
  inLanguage: "de",
  author: { "@id": `${site.domain}/#organization` },
};
---
<BaseLayout title={title} description={description} path="/podcast" schema={schema}>
  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-petrol-800 to-petrol-950 text-sand-100">
    <div class="pointer-events-none absolute -right-32 top-0 h-96 w-96 rounded-full bg-petrol-600/25 blur-3xl"></div>
    <Icon name="paw" class="paw-deco pointer-events-none absolute bottom-8 left-10 h-40 w-40 text-white/[0.04]" />
    <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24 lg:px-8">
      <div class="reveal is-visible">
        <p class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-clay-300">
          <Icon name="microphone" class="h-4 w-4" strokeWidth={2} /> Podcast
        </p>
        <h1 class="mt-3 font-serif text-4xl leading-[1.08] text-white sm:text-5xl">Drei Perspektiven, ein Hund</h1>
        <p class="mt-6 text-lg leading-relaxed text-sand-100/85">
          Jede Folge nimmt einen typischen Fall und zeigt, wie drei Blickwinkel zusammen ein
          vollständigeres Bild ergeben, als jeder für sich. Ehrlich, fachlich und aus der Praxis.
        </p>
        <div class="mt-8">
          <Button href={whatsappLink("Hallo Selin, benachrichtige mich bitte über WhatsApp, sobald der Podcast startet.")} variant="primary" size="lg" external class="wag-hover group">
            <Icon name="paw" class="wag h-5 w-5" />
            Über WhatsApp benachrichtigen lassen
          </Button>
        </div>
      </div>

      <!-- Player-Mock -->
      <div class="reveal is-visible rounded-3xl border border-white/10 bg-white/10 p-6 backdrop-blur-sm sm:p-8">
        <div class="flex items-center gap-4">
          <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-clay-500/25 text-clay-200">
            <Icon name="microphone" class="h-8 w-8" strokeWidth={1.6} />
          </span>
          <div>
            <p class="font-serif text-xl text-white">Drei Perspektiven, ein Hund</p>
            <p class="text-sm text-sand-100/70">Folge 01 · bald verfügbar</p>
          </div>
        </div>
        <!-- Waveform-Deko -->
        <div class="mt-6 flex h-12 items-end gap-1" aria-hidden="true">
          {
            [30, 55, 40, 70, 90, 60, 45, 80, 55, 35, 65, 95, 50, 75, 40, 60, 30, 50, 85, 45, 55, 35, 70, 40].map((h) => (
              <span class="flex-1 rounded-full bg-white/25" style={`height:${h}%`} />
            ))
          }
        </div>
        <div class="mt-6 flex items-center gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-petrol-800">
            <Icon name="play" class="ml-0.5 h-6 w-6" strokeWidth={1.5} />
          </span>
          <div class="h-1.5 flex-1 rounded-full bg-white/15">
            <div class="h-full w-1/4 rounded-full bg-clay-400"></div>
          </div>
          <span class="text-xs text-sand-100/60">–:–</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== DREI STIMMEN ===================== -->
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Die Stimmen</p>
      <h2 class="mt-3 font-serif text-3xl text-petrol-900 sm:text-4xl">Drei echte Experten, ein Hund</h2>
    </div>
    <div class="stagger mt-12 grid gap-6 md:grid-cols-3">
      {
        perspectives.map((p) => (
          <div class="reveal lift group rounded-2xl border border-sand-200 bg-white p-8 text-center hover:border-petrol-200 hover:shadow-md">
            <span class:list={["icon-chip mx-auto flex h-14 w-14", p.chip]}>
              <Icon name={p.icon} class="h-7 w-7" />
            </span>
            <h3 class="mt-5 font-serif text-xl text-petrol-900">{p.role}</h3>
            <p class="mt-3 text-sm leading-relaxed text-sand-600">{p.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===================== WORUM ES GEHT ===================== -->
  <section class="bg-gradient-to-b from-sand-50 to-petrol-50/40 py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="reveal rounded-3xl border border-sand-200 bg-white p-8 shadow-sm sm:p-10">
        <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Worum es geht</p>
        <h2 class="mt-3 font-serif text-2xl text-petrol-900 sm:text-3xl">Ein vollständigeres Bild</h2>
        <p class="mt-4 leading-relaxed text-sand-700">
          Häufig liegt die Wahrheit über die Gesundheit eines Hundes nicht in einer einzelnen
          Disziplin. „Drei Perspektiven, ein Hund“ bringt genau die Stimmen zusammen, die sich in der
          Praxis ergänzen: die tiermedizinische Diagnostik, die körperlich-chiropraktische Sicht und
          den ganzheitlichen Blick auf Ernährung, Homöopathie und Ursache.
        </p>
        <ul class="mt-7 grid gap-4 sm:grid-cols-2">
          {
            format.map((f) => (
              <li class="flex items-start gap-3 rounded-xl border border-sand-200 bg-sand-50 p-4 text-sand-700">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-petrol-100 text-petrol-600">
                  <Icon name={f.icon} class="h-5 w-5" strokeWidth={2} />
                </span>
                <span class="text-sm">{f.t}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <div class="py-24">
    <CtaBanner
      title="Mehr als nur zuhören?"
      text="Im Erst-Check schauen wir gemeinsam konkret auf deinen Hund – persönlich statt allgemein."
    />
  </div>
</BaseLayout>
