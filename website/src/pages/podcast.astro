---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import ImagePlaceholder from "../components/ImagePlaceholder.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { site } from "../data/site";

const title = "Podcast „Drei Perspektiven, ein Hund“";
const description =
  "Der Podcast von Selin Weikard: Tierärztin, Tier-Chiropraktiker und Selin betrachten denselben Hund aus drei Blickwinkeln – für ein vollständigeres Bild von Hundegesundheit.";

const perspectives = [
  {
    role: "Die Tierärztin",
    text: "Bringt die tierärztliche, schulmedizinische Perspektive ein – für eine fundierte Einordnung und klare Grenzen.",
    tone: "petrol" as const,
  },
  {
    role: "Der Tier-Chiropraktiker",
    text: "Steuert die körperliche, chiropraktische Sicht bei – Blockaden, Bewegungsapparat und ihre oft unterschätzte Rolle.",
    tone: "clay" as const,
  },
  {
    role: "Selin Weikard",
    text: "Die ganzheitliche Ursachen-Perspektive aus Homöopathie, Ernährung und drei Jahren echter Erfahrung.",
    tone: "sand" as const,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "PodcastSeries",
  name: "Drei Perspektiven, ein Hund",
  description: description,
  url: `${site.domain}/podcast`,
  inLanguage: "de",
  author: { "@id": `${site.domain}/#organization` },
};
---
<BaseLayout title={title} description={description} path="/podcast" schema={schema}>
  <section class="bg-gradient-to-b from-petrol-50 to-sand-50">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:py-24 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Podcast</p>
      <h1 class="mt-3 font-serif text-4xl text-petrol-900 sm:text-5xl">Drei Perspektiven, ein Hund</h1>
      <p class="prose-lead mx-auto mt-6 max-w-2xl">
        Jede Folge nimmt einen typischen Fall und zeigt, wie drei Blickwinkel zusammen ein
        vollständigeres Bild ergeben, als jeder für sich. Ehrlich, fachlich und aus der Praxis.
      </p>
      <div class="mt-8">
        <Button href={site.bookingUrl} variant="secondary" size="lg" external>Bald verfügbar – Benachrichtigen lassen</Button>
      </div>
    </div>
  </section>

  <!-- Drei Stimmen -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="stagger grid gap-6 md:grid-cols-3">
      {
        perspectives.map((p) => (
          <div class="reveal lift group rounded-2xl border border-sand-200 bg-white p-7 text-center hover:border-petrol-200 hover:shadow-md">
            <div class="mx-auto mb-5 w-full max-w-[180px]">
              <ImagePlaceholder label={`Foto: ${p.role}`} ratio="square" tone={p.tone} />
            </div>
            <h2 class="font-serif text-xl text-petrol-900">{p.role}</h2>
            <p class="mt-3 text-sm leading-relaxed text-sand-600">{p.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Format -->
  <section class="bg-sand-100 py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="reveal rounded-2xl bg-white p-8 shadow-sm sm:p-10">
        <h2 class="font-serif text-2xl text-petrol-900">Worum es geht</h2>
        <p class="mt-4 leading-relaxed text-sand-700">
          Häufig liegt die Wahrheit über die Gesundheit eines Hundes nicht in einer einzelnen
          Disziplin. „Drei Perspektiven, ein Hund“ bringt genau die Stimmen zusammen, die sich in der
          Praxis ergänzen: die tiermedizinische Diagnostik, die körperlich-chiropraktische Sicht und
          den ganzheitlichen Blick auf Ernährung, Homöopathie und Ursache.
        </p>
        <ul class="mt-6 space-y-3 text-sand-700">
          <li class="flex gap-3"><span class="text-petrol-500">•</span> Ein typischer, anonymisierter Fall pro Folge</li>
          <li class="flex gap-3"><span class="text-petrol-500">•</span> Drei echte Experten statt einer Meinung</li>
          <li class="flex gap-3"><span class="text-petrol-500">•</span> Erscheint regelmäßig (geplant: monatlich)</li>
          <li class="flex gap-3"><span class="text-petrol-500">•</span> Für Academy-Mitglieder im vollständigen Archiv</li>
        </ul>
      </div>
    </div>
  </section>

  <div class="py-24">
    <CtaBanner
      title="Mehr als nur zuhören?"
      text="Im Erst-Check schauen wir gemeinsam konkret auf deinen Hund – persönlich statt allgemein."
    />
  </div>
</BaseLayout>
