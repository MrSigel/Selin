---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import Button from "../../components/Button.astro";
import Icon from "../../components/Icon.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { getCollection, render } from "astro:content";
import { site } from "../../data/site";
import cover1 from "../../assets/morpheus-5.jpeg";
import cover2 from "../../assets/morpheus-4.jpeg";
import cover3 from "../../assets/morpheus-2.jpeg";
import cover4 from "../../assets/morpheus-meer.jpeg";

const covers: Record<string, ImageMetadata> = {
  "hund-trotz-tierarzt-nicht-gesund": cover1,
  "darmgesundheit-hund-ausleitung": cover2,
  "ernaehrungsumstellung-hund-wann-hilft": cover3,
  "allergien-hund-symptom-oder-ursache": cover4,
};
const fallback = cover4;

export async function getStaticPaths() {
  const posts = await getCollection("wissen");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const cover = covers[post.id] ?? fallback;

const all = (await getCollection("wissen")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const more = all.filter((p) => p.id !== post.id).slice(0, 2);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("de-DE", { day: "2-digit", month: "long", year: "numeric" });

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    articleSection: post.data.category,
    inLanguage: "de",
    author: { "@type": "Person", name: "Selin Weikard" },
    publisher: { "@id": `${site.domain}/#organization` },
    mainEntityOfPage: `${site.domain}/wissen/${post.id}`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: site.domain },
      { "@type": "ListItem", position: 2, name: "Wissen", item: `${site.domain}/wissen` },
      { "@type": "ListItem", position: 3, name: post.data.title, item: `${site.domain}/wissen/${post.id}` },
    ],
  },
];
---
<BaseLayout title={post.data.title} description={post.data.description} path={`/wissen/${post.id}`} schema={schema}>
  <article>
    <header class="relative overflow-hidden bg-gradient-to-b from-petrol-50 to-sand-50">
      <Icon name="paw" class="paw-deco pointer-events-none absolute -right-4 top-6 h-28 w-28 text-clay-300/20" />
      <div class="relative mx-auto max-w-3xl px-4 py-14 sm:px-6 lg:px-8">
        <nav aria-label="Brotkrümel" class="text-sm text-sand-500">
          <a href="/wissen" class="transition-colors hover:text-petrol-700">Wissen</a>
          <span class="mx-2">/</span>
          <span class="text-sand-700">{post.data.category}</span>
        </nav>
        <h1 class="mt-4 font-serif text-3xl leading-tight text-petrol-900 sm:text-4xl">{post.data.title}</h1>
        <p class="prose-lead mt-4">{post.data.description}</p>
        <div class="mt-5 flex items-center gap-3 text-sm text-sand-500">
          <span class="rounded-full bg-petrol-100 px-2.5 py-1 text-xs font-medium text-petrol-700">{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
          {post.data.readingTime && <><span>·</span><span>{post.data.readingTime}</span></>}
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
      <Image
        src={cover}
        alt={post.data.title}
        widths={[480, 768, 1024]}
        sizes="(max-width: 1024px) 100vw, 768px"
        loading="eager"
        class="mb-10 aspect-[16/9] w-full rounded-2xl object-cover shadow-lg"
      />
      <div class="rich-text">
        <Content />
      </div>

      <div class="mt-12 rounded-2xl border border-sand-200 bg-sand-100 p-6 text-center sm:p-8">
        <p class="font-serif text-xl text-petrol-900">Fragen zu deinem Hund?</p>
        <p class="mt-2 text-sand-700">Im Erst-Check schauen wir gemeinsam auf die eigentliche Ursache.</p>
        <div class="mt-5">
          <Button href="/angebot/erst-check" variant="primary" class="group">
            Erst-Check ansehen
            <Icon name="arrowRight" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" strokeWidth={2} />
          </Button>
        </div>
      </div>
    </div>
  </article>

  {
    more.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 pb-16 sm:px-6 lg:px-8">
        <h2 class="font-serif text-2xl text-petrol-900">Weiterlesen</h2>
        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          {more.map((p) => (
            <a
              href={`/wissen/${p.id}`}
              class="group flex flex-col overflow-hidden rounded-2xl border border-sand-200 bg-white transition-all hover:-translate-y-1 hover:shadow-md"
            >
              <Image
                src={covers[p.id] ?? fallback}
                alt={p.data.title}
                widths={[360, 560]}
                sizes="(max-width: 640px) 100vw, 50vw"
                class="aspect-[16/9] w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="p-5">
                <span class="text-xs font-medium text-petrol-600">{p.data.category}</span>
                <h3 class="mt-1.5 font-serif text-lg leading-snug text-petrol-900 group-hover:text-petrol-700">{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <div class="pb-24">
    <CtaBanner />
  </div>
</BaseLayout>
