---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { site } from "../../data/site";

const title = "Wissen – Fachartikel zu ganzheitlicher Hundegesundheit";
const description =
  "Ehrliche Fachartikel zu Hundegesundheit, Ernährung, Darm, Allergien und Homöopathie – aus echter Erfahrung mit Rhodesian Ridgeback Morpheus.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Wissen – Selin Weikard",
  description,
  url: `${site.domain}/wissen`,
};
---
<BaseLayout title={title} description={description} path="/wissen" schema={schema}>
  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden bg-gradient-to-b from-petrol-50 to-sand-50">
    <Icon name="paw" class="paw-deco pointer-events-none absolute -right-6 top-8 h-32 w-32 text-clay-300/20" />
    <div class="relative mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:py-20 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-clay-600">Wissen</p>
      <h1 class="mt-3 font-serif text-4xl text-petrol-900 sm:text-5xl">Ehrliches Wissen, echte Erfahrung</h1>
      <p class="prose-lead mx-auto mt-6 max-w-2xl">
        Kein Marketing, keine Floskeln – sondern das, was ich in drei Jahren mit Morpheus und
        in meiner Arbeit tatsächlich gelernt habe. Für Hundehalter, die die Ursache verstehen wollen.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Ladezustand -->
    <div id="wissen-loading">
      <div class="animate-pulse overflow-hidden rounded-3xl border border-sand-200 bg-white lg:grid lg:grid-cols-2">
        <div class="min-h-[16rem] bg-sand-200/60"></div>
        <div class="space-y-3 p-8"><div class="h-3 w-24 rounded bg-sand-200/60"></div><div class="h-6 w-3/4 rounded bg-sand-200/60"></div><div class="h-3 w-full rounded bg-sand-200/60"></div></div>
      </div>
    </div>

    <div id="wissen-featured" class="hidden"></div>
    <div id="wissen-grid" class="stagger mt-8 hidden grid gap-8 md:grid-cols-2 lg:grid-cols-3"></div>

    <div id="wissen-empty" class="hidden rounded-2xl border border-dashed border-sand-300 bg-white/60 p-12 text-center">
      <p class="font-serif text-xl text-petrol-900">Artikel folgen in Kürze</p>
      <p class="mt-2 text-sm text-sand-600">Hier entstehen ehrliche Fachbeiträge rund um die Gesundheit deines Hundes.</p>
    </div>
  </section>

  <div class="py-16">
    <CtaBanner
      title="Aus dem Lesen ins Handeln"
      text="Fragen zu deinem Hund lassen sich am besten persönlich klären. Starte mit dem Erst-Check."
    />
  </div>
</BaseLayout>

<script>
  import { listPublishedArtikel, fmtDate, escapeHtml } from "../../lib/db";
  import type { Artikel } from "../../lib/db";

  const loading = document.getElementById("wissen-loading")!;
  const featuredEl = document.getElementById("wissen-featured")!;
  const grid = document.getElementById("wissen-grid")!;
  const empty = document.getElementById("wissen-empty")!;
  const fallbackImg = "/fotos/foto-20.jpeg";

  const meta = (a: Artikel) =>
    `<div class="flex items-center gap-3 text-xs text-sand-500">${
      a.kategorie ? `<span class="rounded-full bg-petrol-100 px-2.5 py-1 font-medium text-petrol-700">${escapeHtml(a.kategorie)}</span>` : ""
    }${a.lesezeit ? `<span>${escapeHtml(a.lesezeit)}</span>` : ""}</div>`;

  function featuredCard(a: Artikel) {
    return `
      <a href="/wissen/beitrag?id=${encodeURIComponent(a.id)}"
         class="reveal is-visible group grid overflow-hidden rounded-3xl border border-sand-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-lg lg:grid-cols-2">
        <div class="relative overflow-hidden">
          <img src="${escapeHtml(a.bild_url || fallbackImg)}" alt="${escapeHtml(a.titel)}" style="object-position:center 28%"
               class="h-full min-h-[16rem] w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <span class="absolute left-4 top-4 rounded-full bg-clay-600 px-3 py-1 text-xs font-semibold text-white">Neuester Artikel</span>
        </div>
        <div class="flex flex-col justify-center p-8 sm:p-10">
          ${meta(a)}
          <h2 class="mt-4 font-serif text-2xl leading-snug text-petrol-900 sm:text-3xl group-hover:text-petrol-700">${escapeHtml(a.titel)}</h2>
          <p class="mt-3 leading-relaxed text-sand-600">${escapeHtml(a.beschreibung || "")}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-medium text-petrol-600 group-hover:text-clay-600">Weiterlesen →</span>
        </div>
      </a>`;
  }

  function gridCard(a: Artikel) {
    return `
      <a href="/wissen/beitrag?id=${encodeURIComponent(a.id)}"
         class="reveal is-visible group flex flex-col overflow-hidden rounded-2xl border border-sand-200 bg-white transition-all duration-200 hover:-translate-y-1 hover:shadow-lg">
        <div class="relative block overflow-hidden">
          <img src="${escapeHtml(a.bild_url || fallbackImg)}" alt="${escapeHtml(a.titel)}" loading="lazy" style="object-position:center 28%"
               class="aspect-[16/9] w-full object-cover transition-transform duration-500 group-hover:scale-105" />
        </div>
        <div class="flex flex-1 flex-col p-6">
          ${meta(a)}
          <h2 class="mt-3 font-serif text-xl leading-snug text-petrol-900 transition-colors group-hover:text-petrol-700">${escapeHtml(a.titel)}</h2>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-sand-600">${escapeHtml(a.beschreibung || "")}</p>
          <div class="mt-4 flex items-center justify-between text-xs text-sand-500">
            <time>${escapeHtml(fmtDate(a.pub_date))}</time>
            <span class="font-medium text-petrol-600 group-hover:text-clay-600">Weiterlesen →</span>
          </div>
        </div>
      </a>`;
  }

  (async () => {
    try {
      const artikel = await listPublishedArtikel(); // neueste zuerst
      loading.classList.add("hidden");
      if (!artikel.length) { empty.classList.remove("hidden"); return; }
      const [first, ...rest] = artikel;
      featuredEl.innerHTML = featuredCard(first);
      featuredEl.classList.remove("hidden");
      if (rest.length) {
        grid.innerHTML = rest.map(gridCard).join("");
        grid.classList.remove("hidden");
      }
    } catch (e) {
      loading.classList.add("hidden");
      empty.classList.remove("hidden");
      console.error("Artikel konnten nicht geladen werden:", e);
    }
  })();
</script>
