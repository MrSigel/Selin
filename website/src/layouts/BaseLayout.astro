---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import SchemaOrg from "../components/SchemaOrg.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { site, legal } from "../data/site";

interface Props {
  title: string;
  description?: string;
  /** Pfad ohne Domain, z. B. "/methode" */
  path?: string;
  /** Optionales zusätzliches Schema.org-Objekt für diese Seite */
  schema?: Record<string, unknown> | Record<string, unknown>[];
  ogImage?: string;
  /** Seite von Suchmaschinen ausschließen (z. B. Login) */
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  path = Astro.url.pathname,
  schema,
  ogImage = "/images/og.png",
  noindex = false,
} = Astro.props;

const canonical = new URL(path, site.domain).href;
const fullTitle =
  title === site.name ? `${site.name} – ${site.tagline}` : `${title} | ${site.name}`;

// Organisation/Person als Basis-Schema auf jeder Seite
const baseSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${site.domain}/#organization`,
  name: `${site.name} – ${site.tagline}`,
  description: site.description,
  url: site.domain,
  email: site.email,
  telephone: site.phone,
  image: new URL("/images/og.png", site.domain).href,
  logo: {
    "@type": "ImageObject",
    url: new URL("/android-chrome-512x512.png", site.domain).href,
    width: 512,
    height: 512,
  },
  slogan: site.claim,
  priceRange: "€€",
  areaServed: "Weltweit",
  availableLanguage: "de",
  address: {
    "@type": "PostalAddress",
    streetAddress: legal.street,
    postalCode: legal.postalCode,
    addressLocality: legal.city,
    addressCountry: "BG",
  },
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: site.email,
    telephone: site.phone,
    availableLanguage: "de",
  },
  founder: {
    "@type": "Person",
    name: site.name,
    jobTitle: "Ganzheitliche Hundegesundheits-Beraterin mit Schwerpunkt Tierhomöopathie",
  },
  knowsAbout: [
    "Ganzheitliche Hundegesundheit",
    "Tierhomöopathie",
    "Hundeernährung",
    "Naturheilkunde für Hunde",
  ],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}
    />

    <!-- Favicons & App-Icons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#172d24" />
    <meta name="msapplication-TileColor" content="#172d24" />
    <meta name="msapplication-TileImage" content="/mstile-150x150.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={new URL(ogImage, site.domain).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Selin Weikard – Ursache statt Symptom" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.domain).href} />

    <SchemaOrg schema={baseSchema} />
    {schema && <SchemaOrg schema={schema} />}
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-petrol-700 focus:px-4 focus:py-2 focus:text-white"
    >
      Zum Inhalt springen
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
    <CookieBanner />

    <script>
      // Sanftes Einblenden beim Scrollen (respektiert prefers-reduced-motion)
      const els = document.querySelectorAll(".reveal");
      if (
        els.length &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px" }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
