---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import SchemaOrg from "../components/SchemaOrg.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description?: string;
  /** Pfad ohne Domain, z. B. "/methode" */
  path?: string;
  /** Optionales zusätzliches Schema.org-Objekt für diese Seite */
  schema?: Record<string, unknown> | Record<string, unknown>[];
  ogImage?: string;
}

const {
  title,
  description = site.description,
  path = Astro.url.pathname,
  schema,
  ogImage = "/images/og-default.svg",
} = Astro.props;

const canonical = new URL(path, site.domain).href;
const fullTitle =
  title === site.name ? `${site.name} – ${site.tagline}` : `${title} | ${site.name}`;

// Organisation/Person als Basis-Schema auf jeder Seite
const baseSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${site.domain}/#organization`,
  name: `${site.name} – ${site.tagline}`,
  description: site.description,
  url: site.domain,
  email: site.email,
  areaServed: "Weltweit",
  availableLanguage: "de",
  founder: {
    "@type": "Person",
    name: site.name,
    jobTitle: "Ganzheitliche Hundegesundheits-Beraterin (in Ausbildung zur Tierheilpraktikerin)",
  },
  knowsAbout: [
    "Ganzheitliche Hundegesundheit",
    "Tierhomöopathie",
    "Hundeernährung",
    "Naturheilkunde für Hunde",
  ],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={new URL(ogImage, site.domain).href} />
    <meta name="twitter:card" content="summary_large_image" />

    <SchemaOrg schema={baseSchema} />
    {schema && <SchemaOrg schema={schema} />}
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-petrol-700 focus:px-4 focus:py-2 focus:text-white"
    >
      Zum Inhalt springen
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />

    <script>
      // Sanftes Einblenden beim Scrollen (respektiert prefers-reduced-motion)
      const els = document.querySelectorAll(".reveal");
      if (
        els.length &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px" }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
