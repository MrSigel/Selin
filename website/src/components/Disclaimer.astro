---
/**
 * Wiederkehrender Compliance-Hinweis (Abschnitt 1, 2, 8 des Konzepts).
 * Hält die Marke seriös und schützt rechtlich.
 */
interface Props {
  class?: string;
  variant?: "box" | "inline";
}
const { class: extra = "", variant = "box" } = Astro.props;
---
{
  variant === "box" ? (
    <aside
      class:list={[
        "flex gap-3 rounded-xl border border-sand-200 bg-sand-100/70 p-4 text-sm text-sand-700",
        extra,
      ]}
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="mt-0.5 shrink-0 text-petrol-600" aria-hidden="true">
        <circle cx="12" cy="12" r="9" />
        <line x1="12" y1="8" x2="12" y2="12" />
        <line x1="12" y1="16" x2="12.01" y2="16" />
      </svg>
      <p>
        <strong class="font-semibold text-petrol-800">Zur Einordnung:</strong> Diese ganzheitliche
        Begleitung ist Coaching und Beratung – kein Ersatz für tierärztliche Diagnose oder
        Notfallbehandlung. Bei akuten oder schweren Beschwerden ist die Tierärztin oder der Tierarzt
        die erste Anlaufstelle. Es werden keine Heilversprechen gegeben.
      </p>
    </aside>
  ) : (
    <p class:list={["text-xs leading-relaxed text-sand-500", extra]}>
      Ganzheitliche Beratung &amp; Begleitung – kein Ersatz für tierärztliche Diagnose oder
      Behandlung. Keine Heilversprechen.
    </p>
  )
}
