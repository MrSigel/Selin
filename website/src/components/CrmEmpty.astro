---
import Icon from "./Icon.astro";
interface Props {
  icon?: string;
  note?: string;
}
const {
  icon = "sparkle",
  note = "Dieser Bereich wird gerade vorbereitet. Die Inhalte folgen in Kürze.",
} = Astro.props;
---
<div class="flex min-h-[60vh] flex-col items-center justify-center rounded-2xl border border-dashed border-sand-300 bg-white/60 p-10 text-center">
  <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-petrol-100 text-petrol-600">
    <Icon name={icon} class="h-7 w-7" strokeWidth={1.8} />
  </span>
  <p class="mt-5 font-serif text-xl text-petrol-900">Bald verfügbar</p>
  <p class="mt-2 max-w-sm text-sm text-sand-600">{note}</p>
</div>
