---
import { Image } from "astro:assets";
import mark from "../assets/mark.png";

interface Props {
  class?: string;
  variant?: "dark" | "light";
}
const { class: extra = "", variant = "dark" } = Astro.props;
const wordColor = variant === "light" ? "text-white" : "text-petrol-900";
const subColor = variant === "light" ? "text-white/70" : "text-petrol-600";
---
<a
  href="/"
  class={`group inline-flex items-center gap-3 ${extra}`}
  aria-label="Startseite Selin Weikard – Ganzheitliche Hundegesundheit"
>
  <Image
    src={mark}
    alt=""
    loading="eager"
    class="h-11 w-auto shrink-0 transition-transform duration-300 group-hover:-translate-y-0.5"
  />
  <span class="flex flex-col leading-none">
    <span class={`font-serif text-lg font-medium tracking-tight ${wordColor}`}>Selin Weikard</span>
    <span class={`mt-1 text-[0.62rem] uppercase tracking-[0.2em] ${subColor}`}>Ganzheitliche Hundegesundheit</span>
  </span>
</a>
