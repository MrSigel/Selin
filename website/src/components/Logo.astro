---
import { Image } from "astro:assets";
import logoDark from "../assets/logo-full.png";
import logoLight from "../assets/logo-full-light.png";

interface Props {
  /** Höhe/Extra-Klassen fürs Logo-Bild, z. B. "h-14" */
  class?: string;
  variant?: "dark" | "light";
}
const { class: extra = "h-12", variant = "dark" } = Astro.props;
// variant "light" = auf dunklem Grund (Footer) → cremefarbenes Logo
const logo = variant === "light" ? logoLight : logoDark;
---
<a
  href="/"
  class="group inline-flex items-center"
  aria-label="Startseite Selin Weikard – Ganzheitliche Hundegesundheit"
>
  <Image
    src={logo}
    alt="Selin Weikard – Ganzheitliche Hundegesundheit"
    loading="eager"
    class={`w-auto shrink-0 transition-transform duration-300 group-hover:-translate-y-0.5 ${extra}`}
  />
</a>
