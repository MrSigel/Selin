---
interface Props {
  class?: string;
  variant?: "dark" | "light";
}
const { class: extra = "", variant = "dark" } = Astro.props;
const mark = variant === "light" ? "#ffffff" : "#2a6b7c";
const accent = variant === "light" ? "#e0aa8b" : "#c9683f";
const wordColor = variant === "light" ? "text-white" : "text-petrol-900";
const subColor = variant === "light" ? "text-white/70" : "text-petrol-600";
---
<a href="/" class={`group inline-flex items-center gap-3 ${extra}`} aria-label="Startseite Selin Weikard">
  <svg width="38" height="38" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="shrink-0 transition-transform duration-300 group-hover:scale-105">
    <circle cx="20" cy="20" r="19" stroke={mark} stroke-width="1.5" opacity="0.5" />
    <!-- stilisierte Pfote -->
    <ellipse cx="20" cy="24.5" rx="6" ry="5" fill={mark} />
    <ellipse cx="13" cy="16.5" rx="2.4" ry="3.2" fill={mark} />
    <ellipse cx="27" cy="16.5" rx="2.4" ry="3.2" fill={mark} />
    <ellipse cx="18" cy="13" rx="2.2" ry="3" fill={mark} />
    <ellipse cx="24" cy="13" rx="2.2" ry="3" fill={accent} />
  </svg>
  <span class="flex flex-col leading-none">
    <span class={`font-serif text-lg font-medium tracking-tight ${wordColor}`}>Selin Weikard</span>
    <span class={`text-[0.68rem] uppercase tracking-[0.18em] ${subColor}`}>Ganzheitliche Hundegesundheit</span>
  </span>
</a>
