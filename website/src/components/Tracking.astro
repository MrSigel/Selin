---
import { tracking } from "../data/site";
const enabled = Boolean(tracking.gtmId || tracking.metaPixelId);
---
{
  enabled && (
    <script is:inline define:vars={{ gtmId: tracking.gtmId, metaPixelId: tracking.metaPixelId }}>
      (function () {
        var loaded = false;
        function load() {
          if (loaded) return;
          loaded = true;
          if (gtmId) {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
            var g = document.createElement("script");
            g.async = true;
            g.src = "https://www.googletagmanager.com/gtm.js?id=" + gtmId;
            document.head.appendChild(g);
          }
          if (metaPixelId) {
            !(function (f, b, e, v, n, t, s) {
              if (f.fbq) return;
              n = f.fbq = function () {
                n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
              };
              if (!f._fbq) f._fbq = n;
              n.push = n; n.loaded = !0; n.version = "2.0"; n.queue = [];
              t = b.createElement(e); t.async = !0;
              t.src = v; s = b.getElementsByTagName(e)[0];
              s.parentNode.insertBefore(t, s);
            })(window, document, "script", "https://connect.facebook.net/en_US/fbevents.js");
            window.fbq("init", metaPixelId);
            window.fbq("track", "PageView");
          }
        }

        // Nur mit Einwilligung laden
        try {
          if (localStorage.getItem("selin-cookie-consent") === "all") load();
        } catch (e) {}
        window.addEventListener("selin-consent-all", load);

        // WhatsApp-Klick = Conversion-Signal
        document.addEventListener("click", function (e) {
          var el = e.target;
          var a = el && el.closest ? el.closest('a[href*="wa.me"]') : null;
          if (!a) return;
          if (window.dataLayer) window.dataLayer.push({ event: "whatsapp_click" });
          if (window.fbq) window.fbq("track", "Lead");
        });
      })();
    </script>
  )
}
