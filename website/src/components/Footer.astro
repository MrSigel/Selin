---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { nav, whatsappLink, site } from "../data/site";
const year = 2026;

const contact = [
  { icon: "paw", label: "Anfrage über WhatsApp", href: whatsappLink(), external: true },
  { icon: "image", label: "Anfrage mit Fotos", href: "/anfrage", external: false },
  { icon: "chat", label: "Kontakt", href: "/kontakt", external: false },
  { icon: "sparkle", label: site.email, href: `mailto:${site.email}`, external: false },
];
---
<footer class="relative mt-24 overflow-hidden bg-gradient-to-b from-petrol-900 to-petrol-950 text-sand-100">
  <div class="h-1 w-full bg-gradient-to-r from-petrol-700 via-clay-500 to-petrol-700"></div>
  <Icon name="paw" class="paw-deco pointer-events-none absolute -bottom-6 right-10 h-48 w-48 text-white/[0.03]" />

  <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <Logo variant="light" class="h-14" />
        <p class="mt-5 max-w-md text-sm leading-relaxed text-sand-200/80">
          Ganzheitliche Begleitung für die Gesundheit deines Hundes – Ursache statt Symptom.
          Aus eigener Erfahrung mit Rhodesian Ridgeback Morpheus. Online, weltweit.
        </p>
        <p class="mt-5 max-w-md font-serif text-lg italic text-sand-100">„{site.claim}"</p>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="wag-hover group mt-6 inline-flex items-center gap-2 rounded-full bg-clay-600 px-5 py-2.5 text-sm font-medium text-white transition-all duration-200 hover:bg-clay-700 hover:-translate-y-0.5"
        >
          <Icon name="paw" class="wag h-4 w-4" />
          Termin anfragen
        </a>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-sand-100">Seiten</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="text-sand-200/80 transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-sand-100">Kontakt</h2>
        <ul class="mt-4 space-y-3 text-sm">
          {
            contact.map((c) => (
              <li>
                <a
                  href={c.href}
                  target={c.external ? "_blank" : undefined}
                  rel={c.external ? "noopener noreferrer" : undefined}
                  class="group flex items-center gap-2.5 text-sand-200/80 transition-colors hover:text-white"
                >
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white/5 text-clay-300 transition-colors group-hover:bg-white/10">
                    <Icon name={c.icon} class="h-4 w-4" strokeWidth={2} />
                  </span>
                  <span>{c.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-petrol-800 pt-8">
      <div class="flex flex-col items-start justify-between gap-4 text-xs text-sand-200/60 sm:flex-row sm:items-center">
        <p>
          © {year} · Powered by
          <a href="https://limit-breakers.eu" target="_blank" rel="noopener noreferrer" class="font-medium text-sand-100 transition-colors hover:text-white">Limit-Breakers</a>
          · Alle Rechte vorbehalten.
        </p>
        <nav aria-label="Rechtliches" class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/impressum" class="transition-colors hover:text-white">Impressum</a>
          <a href="/datenschutz" class="transition-colors hover:text-white">Datenschutz</a>
          <a href="/agb" class="transition-colors hover:text-white">AGB</a>
          <a href="/widerruf" class="transition-colors hover:text-white">Widerruf</a>
          <button type="button" data-open-cookie-settings class="text-left transition-colors hover:text-white">Cookie-Einstellungen</button>
        </nav>
      </div>
    </div>
  </div>
</footer>
