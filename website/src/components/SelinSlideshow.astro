---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import s1 from "../assets/selin-1.jpeg";
import s2 from "../assets/selin-2.jpeg";
import s3 from "../assets/selin-3.jpeg";
import s4 from "../assets/selin-4.jpeg";
import s5 from "../assets/selin-5.jpeg";
import s6 from "../assets/selin-6.jpeg";
import s7 from "../assets/selin-7.jpeg";
import s8 from "../assets/selin-8.jpeg";

const interval = 3600;

const slides = [
  { src: s1, pos: "center 40%", alt: "Selin mit Morpheus im blühenden Rapsfeld" },
  { src: s2, pos: "center 30%", alt: "Selin umarmt Morpheus lachend in den Bergen" },
  { src: s3, pos: "center 30%", alt: "Selin Wange an Wange mit Morpheus im Sonnenlicht" },
  { src: s4, pos: "center 35%", alt: "Selin mit Morpheus im Auto" },
  { src: s5, pos: "65% center", alt: "Selin und Morpheus auf einer gemeinsamen Fahrt" },
  { src: s6, pos: "center 35%", alt: "Selin und Morpheus eng beieinander auf dem Sofa" },
  { src: s7, pos: "center 35%", alt: "Selin mit Morpheus, ruhiger Moment im Auto" },
  { src: s8, pos: "center 35%", alt: "Selin mit dem entspannt dösenden Morpheus im Auto" },
];
---
<div
  class="ss group relative aspect-[3/4] w-full overflow-hidden bg-petrol-900"
  data-slideshow
  role="group"
  aria-label="Bilderfolge: Selin und Morpheus"
  style={`--iv:${interval}ms; --kb:${interval + 1500}ms`}
>
  {
    slides.map((s, i) => (
      <figure class:list={["slide", { "is-active": i === 0 }]}>
        <Image
          src={s.src}
          alt={s.alt}
          widths={[360, 540, 760]}
          sizes="(max-width: 1024px) 90vw, 40vw"
          loading={i === 0 ? "eager" : "lazy"}
          class="slide-img"
          style={`object-position:${s.pos}`}
        />
      </figure>
    ))
  }

  <!-- Story-Fortschrittsbalken oben -->
  <div class="pointer-events-none absolute inset-x-0 top-0 z-20 bg-gradient-to-b from-black/40 to-transparent p-3">
    <div class="flex gap-1.5">
      {slides.map((_, i) => (
        <span class:list={["bar", { "is-active": i === 0 }]}>
          <span class="bar-fill" />
        </span>
      ))}
    </div>
  </div>

  <!-- Label unten -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20 flex items-end justify-between bg-gradient-to-t from-black/55 to-transparent p-4">
    <span class="font-serif text-lg text-white drop-shadow">Selin &amp; Morpheus</span>
    <span class="flex items-center gap-1.5 rounded-full bg-white/15 px-2.5 py-1 text-xs font-medium text-white backdrop-blur-sm">
      <Icon name="paw" class="h-3.5 w-3.5 text-clay-300" />
      ein Team
    </span>
  </div>
</div>

<style>
  .slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transition: opacity 1.1s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .slide.is-active {
    opacity: 1;
    z-index: 10;
  }
  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.015);
  }
  .bar {
    position: relative;
    display: block;
    flex: 1 1 0;
    height: 3px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.32);
    overflow: hidden;
  }
  .bar-fill {
    display: block;
    height: 100%;
    width: 0%;
    background: #fff;
    border-radius: 9999px;
  }
  .bar.is-done .bar-fill {
    width: 100%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .slide.is-active .slide-img {
      animation: kenburns var(--kb, 5s) ease-out both;
    }
    .bar.is-active .bar-fill {
      animation: fillbar var(--iv, 3600ms) linear forwards;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .bar.is-active .bar-fill {
      width: 100%;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-slideshow].ss").forEach((root) => {
    const slides = [...root.querySelectorAll<HTMLElement>(".slide")];
    const bars = [...root.querySelectorAll<HTMLElement>(".bar")];
    if (slides.length < 2) return;

    const interval = parseInt(root.style.getPropertyValue("--iv")) || 3600;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const show = (n: number) => {
      slides.forEach((s, k) => s.classList.toggle("is-active", k === n));
      bars.forEach((b, k) => {
        b.classList.remove("is-active", "is-done");
        if (k < n) b.classList.add("is-done");
        else if (k === n) b.classList.add("is-active");
      });
    };

    const next = () => {
      i = (i + 1) % slides.length;
      show(i);
    };

    show(0);
    if (reduce) return;

    const start = () => {
      stop();
      timer = setInterval(next, interval);
    };
    const stop = () => {
      if (timer) clearInterval(timer);
      timer = undefined;
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !document.hidden) start();
          else stop();
        }
      },
      { threshold: 0.35 }
    );
    io.observe(root);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else if (root.getBoundingClientRect().top < window.innerHeight) start();
    });
  });
</script>
