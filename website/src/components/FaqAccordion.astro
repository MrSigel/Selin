---
interface Props {
  items: { q: string; a: string }[];
}
const { items } = Astro.props;
---
<div class="divide-y divide-sand-200 overflow-hidden rounded-2xl border border-sand-200 bg-white">
  {
    items.map((item, i) => (
      <details class="group" open={i === 0}>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 text-left font-medium text-petrol-900 transition-colors hover:bg-sand-50 sm:px-6">
          <span class="font-serif text-lg">{item.q}</span>
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="shrink-0 text-petrol-500 transition-transform duration-200 group-open:rotate-45"
            aria-hidden="true"
          >
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        </summary>
        <div class="px-5 pb-6 text-sand-700 leading-relaxed sm:px-6">
          {item.a}
        </div>
      </details>
    ))
  }
</div>
