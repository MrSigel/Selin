---
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import { whatsappLink, site } from "../data/site";
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Bereit, die Ursache zu finden?",
  text = "Der Erst-Check ist der erste ehrliche Blick auf deinen Hund – unverbindlich anfragen und herausfinden, ob wir zusammenpassen.",
} = Astro.props;
---
<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="reveal relative overflow-hidden rounded-3xl bg-petrol-800 px-6 py-14 text-center sm:px-12 sm:py-16">
    <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-petrol-700/50 blur-2xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-10 h-64 w-64 rounded-full bg-clay-500/20 blur-2xl"></div>
    <Icon name="paw" class="paw-deco pointer-events-none absolute right-8 top-8 h-12 w-12 text-white/10" />
    <Icon name="paw" class="paw-deco-alt pointer-events-none absolute bottom-10 left-10 h-8 w-8 text-white/10" />
    <div class="relative mx-auto max-w-2xl">
      <h2 class="font-serif text-3xl text-white sm:text-4xl">{title}</h2>
      <p class="mt-4 text-lg leading-relaxed text-sand-100/85">{text}</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Button href={whatsappLink()} variant="primary" size="lg" external class="wag-hover group">
          <Icon name="paw" class="wag h-5 w-5" />
          Erst-Check anfragen
        </Button>
        <Button href={site.bookingUrl} variant="white" size="lg" external>
          Termin buchen
        </Button>
      </div>
      <p class="mt-6 font-serif text-lg italic text-sand-100/70">„{site.claim}"</p>
    </div>
  </div>
</section>
