---
/**
 * Signatur-Element „Unter der Oberfläche“:
 * eine feine Oberflächenlinie, aus der eine Wurzel nach unten wächst.
 * Encodiert das Markenversprechen – Ursache statt Symptom.
 */
interface Props {
  class?: string;
}
const { class: extra = "" } = Astro.props;
---
<div
  class:list={[
    "reveal surface-divider mx-auto flex max-w-7xl items-start px-4 py-8 sm:px-6 lg:px-8",
    extra,
  ]}
  aria-hidden="true"
>
  <span class="mt-px h-px flex-1 bg-gradient-to-r from-transparent via-sand-300 to-sand-300"></span>
  <svg
    width="64"
    height="46"
    viewBox="0 0 64 46"
    fill="none"
    class="shrink-0 text-clay-500"
  >
    <circle cx="32" cy="1.5" r="2.4" fill="currentColor" />
    <path
      class="root-path"
      d="M32 4 C32 12 32 16 32 22 M32 22 C32 28 27 30 22 37 M32 22 C32 28 37 30 42 38 M32 16 C32 18 28 20 25 23 M32 18 C32 20 36 22 40 24"
      stroke="currentColor"
      stroke-width="1.3"
      stroke-linecap="round"
    />
  </svg>
  <span class="mt-px h-px flex-1 bg-gradient-to-l from-transparent via-sand-300 to-sand-300"></span>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .root-path {
      stroke-dasharray: 130;
      stroke-dashoffset: 130;
    }
    .surface-divider.is-visible .root-path {
      animation: root-grow 1.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  }
  @keyframes root-grow {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
